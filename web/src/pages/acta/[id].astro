---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import { getPleno, getPuntosPleno, getVotacionesPunto, supabase,
         CATEGORIAS, TIPO_LABEL, RESULTADO_LABEL } from '../../lib/supabase';

const { id } = Astro.params;
const pleno = await getPleno(id!);
if (!pleno) return Astro.redirect("/actas");

const [puntos, { data: meta }] = await Promise.all([
  getPuntosPleno(id!),
  supabase
    .from("plenos")
    .select("url_pdf_original, n_asistentes, n_ausentes, alcalde_nombre, secretaria_nombre, hora_inicio, hora_fin, municipio_id")
    .eq("id", id!)
    .single(),
]);

// Votaciones para todos los puntos
const votacionesPorPunto: Record<string, any[]> = {};
await Promise.all(
  puntos.map(async (p) => {
    const v = await getVotacionesPunto(p.id);
    if (v.length > 0) votacionesPorPunto[p.id] = v;
  })
);

// ── Resumen por partido (acumulado del pleno) ────────────────────────────────
const partidoMap: Record<string, { siglas: string; partido: string; color_hex: string; favor: number; contra: number; abstenciones: number; nPuntos: number }> = {};
for (const votos of Object.values(votacionesPorPunto)) {
  for (const v of votos) {
    if (!partidoMap[v.siglas]) {
      partidoMap[v.siglas] = { siglas: v.siglas, partido: v.partido, color_hex: v.color_hex, favor: 0, contra: 0, abstenciones: 0, nPuntos: 0 };
    }
    partidoMap[v.siglas].favor       += v.votos_favor;
    partidoMap[v.siglas].contra      += v.votos_contra;
    partidoMap[v.siglas].abstenciones+= v.abstenciones;
    partidoMap[v.siglas].nPuntos++;
  }
}
const resumenPartidos = Object.values(partidoMap).sort((a, b) => b.favor - a.favor);

// Puntos polémicos: tiene votos Y no es unánime
const puntosControversia = puntos.filter((p) => {
  const v = votacionesPorPunto[p.id];
  return v && v.length > 0 && !p.unanimidad && (p.resultado === "aprobado" || p.resultado === "rechazado");
});

// Municipio info para breadcrumb
let municipioSlug   = "";
let municipioNombre = pleno.municipio ?? "San Sebastián";
if (meta?.municipio_id) {
  try {
    const { data: muni } = await supabase
      .from("municipios")
      .select("slug, nombre")
      .eq("id", meta.municipio_id)
      .single();
    municipioSlug   = muni?.slug   ?? "";
    municipioNombre = muni?.nombre ?? municipioNombre;
  } catch {}
}

// ── Fechas ───────────────────────────────────────────────────────────────────
const fecha = new Date(pleno.fecha + "T12:00:00");
const fechaLarga = fecha.toLocaleDateString("es-ES", {
  weekday: "long", day: "numeric", month: "long", year: "numeric",
});
const fechaCorta = fecha.toLocaleDateString("es-ES", {
  day: "numeric", month: "short", year: "numeric",
});

// ── Categorías únicas ─────────────────────────────────────────────────────────
const categorias = [...new Set(
  puntos.map((p) => p.categoria).filter((c) => c && c !== "otro")
)];

// ── Puntos agrupados ──────────────────────────────────────────────────────────
const puntosUrgentes     = puntos.filter((p) => p.es_urgencia);
const puntosResolutivos  = puntos.filter((p) => !p.es_urgencia && !["dar_cuenta","otro"].includes(p.tipo));
const puntosInformativos = puntos.filter((p) => !p.es_urgencia &&  ["dar_cuenta","otro"].includes(p.tipo));
---

<Base
  title={`Pleno nº ${pleno.numero_acta} · ${fechaCorta} · ${municipioNombre}`}
  description={`Pleno municipal de ${municipioNombre} nº ${pleno.numero_acta}, ${fechaLarga}. ${puntos.length} puntos del orden del día.`}
>

  <!-- ── MIGAS ───────────────────────────────────────────────────────────── -->
  <nav class="flex items-center gap-2 text-xs text-[var(--color-ink-muted)] mb-6 flex-wrap">
    <a href="/" class="hover:underline">Inicio</a>
    <span>/</span>
    {municipioSlug
      ? <a href={`/ciudad/${municipioSlug}`} class="hover:underline">{municipioNombre}</a>
      : <span>{municipioNombre}</span>}
    <span>/</span>
    <span class="text-[var(--color-ink)] font-medium">Pleno nº {pleno.numero_acta}</span>
  </nav>

  <!-- ── CABECERA ────────────────────────────────────────────────────────── -->
  <header class="mb-8 pb-8 border-b-2 border-[var(--color-ink)]">
    <div class="flex flex-wrap items-center gap-3 mb-3">
      <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-ink-muted)]">
        {municipioNombre} · Pleno nº {pleno.numero_acta}
      </span>
      <span class:list={[
        "badge",
        pleno.tipo_sesion === "extraordinaria"
          ? "bg-amber-100 text-amber-800"
          : "bg-[var(--color-accent-light)] text-[var(--color-accent)]",
      ]}>
        Sesión {pleno.tipo_sesion}
      </span>
    </div>

    <h1 class="headline-xl mb-4" style="text-transform: capitalize;">{fechaLarga}</h1>

    {pleno.resumen_ia && (
      <p class="text-base text-[var(--color-ink-muted)] leading-relaxed border-l-4 border-[var(--color-accent)] pl-4 max-w-2xl mb-4">
        {pleno.resumen_ia}
      </p>
    )}

    <!-- Ficha rápida -->
    <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-[var(--color-ink-muted)]">
      {meta?.alcalde_nombre && <span>Preside: <strong class="text-[var(--color-ink)]">{meta.alcalde_nombre}</strong></span>}
      {meta?.hora_inicio && <span>Inicio: <strong class="text-[var(--color-ink)]">{String(meta.hora_inicio).slice(0,5)} h</strong></span>}
      {(meta?.n_asistentes ?? 0) > 0 && (
        <span>
          Asistencia: <strong class="text-[var(--color-ink)]">{meta!.n_asistentes} concejales</strong>
          {(meta?.n_ausentes ?? 0) > 0 && <span> · {meta!.n_ausentes} ausentes</span>}
        </span>
      )}
      {meta?.url_pdf_original && (
        <a href={meta.url_pdf_original} target="_blank" rel="noopener noreferrer"
           class="ml-auto font-semibold text-[var(--color-accent)] hover:underline flex items-center gap-1">
          ↓ Descargar acta en PDF
        </a>
      )}
    </div>
  </header>

  <!-- ── STATS ──────────────────────────────────────────────────────────── -->
  <section class="mb-8">
    <div class="grid grid-cols-3 sm:grid-cols-6 border border-[var(--color-border)] divide-x divide-y sm:divide-y-0 divide-[var(--color-border)]">
      {[
        { label: "Puntos",      value: pleno.total_puntos,         cls: "" },
        { label: "Aprobados",   value: pleno.aprobados,            cls: "text-[var(--color-green)]" },
        { label: "Rechazados",  value: pleno.rechazados,           cls: "text-[var(--color-red)]" },
        { label: "Unanimidad",  value: pleno.unanimes,             cls: "" },
        { label: "Polémicos",   value: puntosControversia.length,  cls: puntosControversia.length > 0 ? "text-[var(--color-amber)]" : "" },
        { label: "Concejales",  value: meta?.n_asistentes ?? "—",  cls: "" },
      ].map(({ label, value, cls }) => (
        <div class="text-center py-5 px-2 bg-white">
          <p class:list={["font-serif font-bold text-3xl", cls]}>{value}</p>
          <p class="text-[10px] uppercase tracking-widest text-[var(--color-ink-muted)] mt-1">{label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── POSICIÓN DE LOS PARTIDOS ──────────────────────────────────────── -->
  {resumenPartidos.length > 0 && (
    <section class="mb-10">
      <div class="section-rule mb-4">
        <span class="text-xs font-bold uppercase tracking-widest">Posición de los partidos en este pleno</span>
      </div>

      <div class="border border-[var(--color-border)] bg-white overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[var(--color-border)]">
              <th class="text-left px-4 py-2 text-[10px] uppercase tracking-widest text-[var(--color-ink-muted)] font-semibold w-1/3">Partido</th>
              <th class="text-center px-3 py-2 text-[10px] uppercase tracking-widest text-[var(--color-green)] font-semibold">A favor</th>
              <th class="text-center px-3 py-2 text-[10px] uppercase tracking-widest text-[var(--color-red)] font-semibold">En contra</th>
              <th class="text-center px-3 py-2 text-[10px] uppercase tracking-widest text-[var(--color-ink-muted)] font-semibold">Abstención</th>
              <th class="text-center px-3 py-2 text-[10px] uppercase tracking-widest text-[var(--color-ink-muted)] font-semibold hidden sm:table-cell">Puntos votados</th>
              <th class="text-left px-4 py-2 text-[10px] uppercase tracking-widest text-[var(--color-ink-muted)] font-semibold hidden md:table-cell">Perfil</th>
            </tr>
          </thead>
          <tbody>
            {resumenPartidos.map((p) => {
              const total = p.favor + p.contra + p.abstenciones;
              const pctFavor = total > 0 ? Math.round((p.favor / total) * 100) : 0;
              const perfil = p.contra > p.favor
                ? { label: "Principalmente en contra", cls: "text-[var(--color-red)]" }
                : p.abstenciones > p.favor && p.abstenciones > p.contra
                ? { label: "Se abstiene habitualmente", cls: "text-[var(--color-ink-muted)]" }
                : pctFavor === 100
                ? { label: "Vota siempre a favor", cls: "text-[var(--color-green)]" }
                : { label: "Mayoritariamente a favor", cls: "text-[var(--color-green)]" };
              return (
                <tr class="border-b border-[var(--color-border)] last:border-0 hover:bg-[var(--color-bg)]">
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-2">
                      <span class="w-2.5 h-2.5 rounded-full shrink-0" style={`background: ${p.color_hex}`} />
                      <span class="font-semibold">{p.siglas}</span>
                      <span class="text-[var(--color-ink-muted)] text-xs hidden lg:inline truncate max-w-[160px]">{p.partido}</span>
                    </div>
                  </td>
                  <td class="px-3 py-3 text-center">
                    <span class="font-bold text-[var(--color-green)]">{p.favor}</span>
                  </td>
                  <td class="px-3 py-3 text-center">
                    <span class:list={["font-bold", p.contra > 0 ? "text-[var(--color-red)]" : "text-[var(--color-ink-subtle)]"]}>
                      {p.contra > 0 ? p.contra : "—"}
                    </span>
                  </td>
                  <td class="px-3 py-3 text-center">
                    <span class:list={["font-bold", p.abstenciones > 0 ? "text-[var(--color-amber)]" : "text-[var(--color-ink-subtle)]"]}>
                      {p.abstenciones > 0 ? p.abstenciones : "—"}
                    </span>
                  </td>
                  <td class="px-3 py-3 text-center text-[var(--color-ink-muted)] hidden sm:table-cell">
                    {p.nPuntos}
                  </td>
                  <td class="px-4 py-3 hidden md:table-cell">
                    <span class:list={["text-xs", perfil.cls]}>{perfil.label}</span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {/* Puntos polémicos */}
      {puntosControversia.length > 0 && (
        <div class="mt-4 p-4 border border-[var(--color-border)] bg-white">
          <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-ink-muted)] mb-3">
            Puntos con votación dividida ({puntosControversia.length})
          </p>
          <div class="space-y-2">
            {puntosControversia.map((p) => (
              <div class="flex items-start gap-3 text-sm">
                <span class="font-mono text-xs text-[var(--color-ink-subtle)] shrink-0 mt-0.5 w-5">{p.numero}.</span>
                <span class="flex-1 leading-snug text-[var(--color-ink)]">{p.titulo}</span>
                <span class:list={[
                  "shrink-0 text-xs font-semibold",
                  p.resultado === "aprobado" ? "text-[var(--color-green)]" : "text-[var(--color-red)]"
                ]}>
                  {RESULTADO_LABEL[p.resultado]}
                </span>
              </div>
            ))}
          </div>
        </div>
      )}
    </section>
  )}

  <!-- ── TEMAS TRATADOS ─────────────────────────────────────────────────── -->
  {categorias.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-10">
      {categorias.map((cat) => (
        <a href={`/temas/${cat}`}
           class:list={["badge hover:opacity-75 transition-opacity", `badge-${cat}`]}>
          {CATEGORIAS[cat] ?? cat}
        </a>
      ))}
    </div>
  )}

  <!-- ── ORDEN DEL DÍA ──────────────────────────────────────────────────── -->
  <section class="mb-10">
    <div class="section-rule mb-6">
      <span class="text-xs font-bold uppercase tracking-widest">
        Orden del día — {puntos.length} {puntos.length === 1 ? "punto" : "puntos"}
      </span>
    </div>

    {puntos.length === 0 ? (
      <p class="text-[var(--color-ink-muted)] text-sm py-12 text-center border border-dashed border-[var(--color-border)]">
        Los puntos del orden del día se están procesando.
      </p>
    ) : (
      <div class="space-y-3">

        <!-- Urgencias -->
        {puntosUrgentes.map((p) => {
          const votos = votacionesPorPunto[p.id] ?? [];
          return (
            <div class="border border-[var(--color-amber)] bg-[var(--color-amber-bg)] rounded-[var(--radius)] p-5">
              <div class="flex flex-wrap items-start gap-x-4 gap-y-2">
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap gap-2 mb-2">
                    <span class="badge" style="background: var(--color-amber-bg); color: var(--color-amber);">Urgencia</span>
                    {p.categoria !== "otro" && (
                      <span class:list={["badge", `badge-${p.categoria}`]}>{CATEGORIAS[p.categoria]}</span>
                    )}
                    <span class="text-[10px] border border-[var(--color-border)] rounded px-1.5 text-[var(--color-ink-muted)]">
                      {TIPO_LABEL[p.tipo] ?? p.tipo}
                    </span>
                  </div>
                  <p class="font-serif font-semibold text-base leading-snug mb-2">{p.titulo}</p>
                  {p.resumen_ia && <p class="text-sm text-[var(--color-ink-muted)] leading-relaxed">{p.resumen_ia}</p>}
                  {votos.length > 0 && (
                    <VotacionDetalle votos={votos} unanimidad={p.unanimidad} />
                  )}
                </div>
                <div class="shrink-0 text-right">
                  <ResultadoBadge resultado={p.resultado} unanimidad={p.unanimidad} />
                </div>
              </div>
            </div>
          );
        })}

        <!-- Parte resolutiva -->
        {puntosResolutivos.length > 0 && (
          <div>
            {puntosUrgentes.length > 0 && (
              <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-ink-muted)] py-3 mt-1">
                — Parte resolutiva
              </p>
            )}
            {puntosResolutivos.map((p) => {
              const votos = votacionesPorPunto[p.id] ?? [];
              const esPolemico = votos.length > 0 && !p.unanimidad && (p.resultado === "aprobado" || p.resultado === "rechazado");
              return (
                <div class:list={[
                  "border bg-white rounded-[var(--radius)] p-5 mb-3",
                  esPolemico
                    ? "border-[var(--color-amber)]"
                    : (p.relevancia_social ?? 0) >= 4
                    ? "border-l-4 border-l-[var(--color-accent)] border-[var(--color-border)]"
                    : "border-[var(--color-border)]",
                ]}>
                  <div class="flex flex-wrap items-start gap-x-4 gap-y-2">
                    <span class="font-mono text-sm font-bold text-[var(--color-ink-subtle)] w-6 shrink-0 mt-0.5">
                      {p.numero}.
                    </span>
                    <div class="flex-1 min-w-0">
                      <!-- Badges -->
                      <div class="flex flex-wrap gap-2 mb-2">
                        {p.categoria !== "otro" && (
                          <span class:list={["badge", `badge-${p.categoria}`]}>{CATEGORIAS[p.categoria]}</span>
                        )}
                        <span class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)] border border-[var(--color-border)] rounded px-1.5 py-0.5">
                          {TIPO_LABEL[p.tipo] ?? p.tipo}
                        </span>
                        {(p.relevancia_social ?? 0) >= 4 && (
                          <span class="flex items-center gap-1 text-[10px] text-[var(--color-accent)]">
                            {Array.from({ length: p.relevancia_social ?? 0 }).map(() => (
                              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] inline-block" />
                            ))}
                            <span class="uppercase tracking-wide ml-0.5">Alta relevancia</span>
                          </span>
                        )}
                        {esPolemico && (
                          <span class="text-[10px] font-semibold uppercase tracking-wide" style="color: var(--color-amber);">
                            Votación dividida
                          </span>
                        )}
                      </div>

                      <!-- Título -->
                      <p class="font-serif font-semibold text-base leading-snug">{p.titulo}</p>

                      <!-- Resumen IA -->
                      {p.resumen_ia && (
                        <p class="text-sm text-[var(--color-ink-muted)] mt-2 leading-relaxed">{p.resumen_ia}</p>
                      )}

                      <!-- Votaciones por partido -->
                      {votos.length > 0 && (
                        <div class="mt-4 pt-3 border-t border-[var(--color-border)]">
                          <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-ink-muted)] mb-3">
                            Desglose de votos
                          </p>
                          <div class="overflow-x-auto">
                            <table class="text-xs w-full">
                              <thead>
                                <tr class="text-[var(--color-ink-muted)]">
                                  <th class="text-left pb-1 pr-4 font-semibold uppercase tracking-wider text-[10px]">Partido</th>
                                  <th class="text-center pb-1 px-3 font-semibold uppercase tracking-wider text-[10px] text-[var(--color-green)]">A favor</th>
                                  <th class="text-center pb-1 px-3 font-semibold uppercase tracking-wider text-[10px] text-[var(--color-red)]">En contra</th>
                                  <th class="text-center pb-1 px-3 font-semibold uppercase tracking-wider text-[10px] text-[var(--color-amber)]">Abstención</th>
                                </tr>
                              </thead>
                              <tbody>
                                {votos.map((v) => (
                                  <tr class="border-t border-[var(--color-border)]">
                                    <td class="py-2 pr-4">
                                      <div class="flex items-center gap-2">
                                        <span class="w-2 h-2 rounded-full shrink-0" style={`background: ${v.color_hex}`} />
                                        <span class="font-semibold">{v.siglas}</span>
                                      </div>
                                    </td>
                                    <td class="py-2 px-3 text-center">
                                      {v.votos_favor > 0
                                        ? <span class="font-bold text-[var(--color-green)]">{v.votos_favor}</span>
                                        : <span class="text-[var(--color-ink-subtle)]">—</span>}
                                    </td>
                                    <td class="py-2 px-3 text-center">
                                      {v.votos_contra > 0
                                        ? <span class="font-bold text-[var(--color-red)]">{v.votos_contra}</span>
                                        : <span class="text-[var(--color-ink-subtle)]">—</span>}
                                    </td>
                                    <td class="py-2 px-3 text-center">
                                      {v.abstenciones > 0
                                        ? <span class="font-bold text-[var(--color-amber)]">{v.abstenciones}</span>
                                        : <span class="text-[var(--color-ink-subtle)]">—</span>}
                                    </td>
                                  </tr>
                                ))}
                              </tbody>
                              <!-- Totales -->
                              {votos.length > 1 && (() => {
                                const totFavor = votos.reduce((s, v) => s + v.votos_favor, 0);
                                const totContra = votos.reduce((s, v) => s + v.votos_contra, 0);
                                const totAbst  = votos.reduce((s, v) => s + v.abstenciones, 0);
                                return (
                                  <tfoot>
                                    <tr class="border-t-2 border-[var(--color-border-strong)] bg-[var(--color-bg)]">
                                      <td class="py-1.5 pr-4 text-[10px] font-bold uppercase tracking-wider text-[var(--color-ink-muted)]">Total</td>
                                      <td class="py-1.5 px-3 text-center font-bold text-[var(--color-green)]">{totFavor}</td>
                                      <td class="py-1.5 px-3 text-center font-bold text-[var(--color-red)]">{totContra > 0 ? totContra : "—"}</td>
                                      <td class="py-1.5 px-3 text-center font-bold text-[var(--color-amber)]">{totAbst > 0 ? totAbst : "—"}</td>
                                    </tr>
                                  </tfoot>
                                );
                              })()}
                            </table>
                          </div>
                        </div>
                      )}

                      {/* Sin votos pero aprobado/rechazado */}
                      {votos.length === 0 && (p.resultado === "aprobado" || p.resultado === "rechazado") && (
                        <p class="text-xs text-[var(--color-ink-subtle)] mt-3 italic">
                          {p.unanimidad ? "Aprobado por unanimidad sin detalle de votos registrado." : "Sin desglose de votos disponible."}
                        </p>
                      )}
                    </div>

                    <!-- Resultado -->
                    <div class="shrink-0 mt-0.5 text-right min-w-[72px]">
                      {p.resultado === "aprobado" && (
                        <span class="inline-block px-2 py-0.5 text-xs font-bold rounded" style="background: var(--color-green-bg); color: var(--color-green);">
                          Aprobado
                        </span>
                      )}
                      {p.resultado === "rechazado" && (
                        <span class="inline-block px-2 py-0.5 text-xs font-bold rounded" style="background: var(--color-red-bg); color: var(--color-red);">
                          Rechazado
                        </span>
                      )}
                      {!["aprobado","rechazado"].includes(p.resultado) && (
                        <span class="text-xs text-[var(--color-ink-muted)]">
                          {RESULTADO_LABEL[p.resultado] ?? p.resultado}
                        </span>
                      )}
                      {p.unanimidad === true && (
                        <p class="text-[10px] text-[var(--color-ink-subtle)] mt-0.5">unanimidad</p>
                      )}
                      {p.unanimidad === false && (
                        <p class="text-[10px] text-[var(--color-ink-subtle)] mt-0.5">mayoría</p>
                      )}
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        )}

        <!-- Puntos informativos (dar cuenta) colapsable -->
        {puntosInformativos.length > 0 && (
          <details class="group mt-4">
            <summary class="section-rule mb-0 cursor-pointer list-none flex items-center justify-between py-2">
              <span class="text-xs font-bold uppercase tracking-widest">
                Informes y comunicaciones ({puntosInformativos.length})
              </span>
              <span class="text-xs text-[var(--color-ink-muted)] group-open:hidden">Mostrar ↓</span>
              <span class="text-xs text-[var(--color-ink-muted)] hidden group-open:block">Cerrar ↑</span>
            </summary>
            <div class="mt-3 space-y-2">
              {puntosInformativos.map((p) => (
                <div class="border border-[var(--color-border)] bg-white rounded-[var(--radius)] px-5 py-3 flex items-start gap-4">
                  <span class="font-mono text-xs text-[var(--color-ink-muted)] shrink-0 mt-0.5 w-5">{p.numero}.</span>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium leading-snug">{p.titulo}</p>
                    {p.resumen_ia && (
                      <p class="text-xs text-[var(--color-ink-muted)] mt-1 leading-relaxed">{p.resumen_ia}</p>
                    )}
                    {p.categoria && p.categoria !== "otro" && (
                      <span class:list={["badge mt-1.5", `badge-${p.categoria}`]}>{CATEGORIAS[p.categoria]}</span>
                    )}
                  </div>
                  <span class="text-xs text-[var(--color-ink-subtle)] shrink-0">Enterado</span>
                </div>
              ))}
            </div>
          </details>
        )}
      </div>
    )}
  </section>

  <!-- ── NAV INFERIOR ───────────────────────────────────────────────────── -->
  <div class="border-t border-[var(--color-border)] pt-6 flex flex-wrap justify-between items-center gap-4">
    <div class="flex items-center gap-6">
      {municipioSlug
        ? <a href={`/ciudad/${municipioSlug}`} class="text-sm font-semibold hover:underline">← Todas las actas</a>
        : <a href="/actas" class="text-sm font-semibold hover:underline">← Todas las actas</a>}
      {meta?.url_pdf_original && (
        <a href={meta.url_pdf_original} target="_blank" rel="noopener noreferrer"
           class="text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-ink)] hover:underline">
          ↓ Acta en PDF
        </a>
      )}
    </div>
    <a href="/newsletter" class="text-sm font-semibold text-[var(--color-accent)] hover:underline">
      Suscribirse a la newsletter →
    </a>
  </div>

</Base>
