---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import VotacionToggle from '../../components/VotacionToggle';
import ParlamentArc from '../../components/ParlamentArc';
import AsistenciaWidget from '../../components/AsistenciaWidget';
import { getPleno, getPuntosPleno, getVotacionesPunto, getAsistenciaPleno, supabase,
         CATEGORIAS, TIPO_LABEL, RESULTADO_LABEL } from '../../lib/supabase';

const { id } = Astro.params;
const pleno = await getPleno(id!);
if (!pleno) return Astro.redirect("/actas");

const [puntos, { data: meta }, asistenciaPartidos] = await Promise.all([
  getPuntosPleno(id!),
  supabase
    .from("plenos")
    .select("url_pdf_original, n_asistentes, n_ausentes, alcalde_nombre, secretaria_nombre, hora_inicio, hora_fin, municipio_id")
    .eq("id", id!)
    .single(),
  getAsistenciaPleno(id!),
]);

const { data: puntosMeta } = await supabase
  .from("puntos")
  .select("id, relevancia_social, grupo_proponente_id, partidos:grupo_proponente_id(siglas)")
  .eq("pleno_id", id!);

const puntoExtraById = new Map(
  (puntosMeta ?? []).map((row: any) => [
    row.id,
    {
      relevancia: row.relevancia_social ?? 0,
      proponente: row.partidos?.siglas ?? null,
    },
  ])
);

// Votaciones para todos los puntos
const votacionesPorPunto: Record<string, any[]> = {};
await Promise.all(
  puntos.map(async (p) => {
    const v = await getVotacionesPunto(p.id);
    if (v.length > 0) votacionesPorPunto[p.id] = v;
  })
);

// Concejales por partido: oficial (n_concejales) o máximo votos como fallback
const partidoMeta: Record<string, { maxVotos: number; color: string; n_concejales: number | null }> = {};
for (const votos of Object.values(votacionesPorPunto)) {
  for (const v of votos) {
    const total = v.votos_favor + v.votos_contra + v.abstenciones;
    if (!partidoMeta[v.siglas]) {
      partidoMeta[v.siglas] = { maxVotos: 0, color: v.color_hex ?? "#888", n_concejales: v.n_concejales ?? null };
    }
    if (total > partidoMeta[v.siglas].maxVotos) partidoMeta[v.siglas].maxVotos = total;
  }
}

// Composición ordenada por escaños (mayor → menor)
const composicion = Object.entries(partidoMeta)
  .map(([siglas, m]) => ({
    sigla: siglas,
    concejales: m.n_concejales ?? m.maxVotos,
    color: m.color,
  }))
  .sort((a, b) => b.concejales - a.concejales);
const totalConcejales = composicion.reduce((s, p) => s + p.concejales, 0);

// Puntos polémicos
const puntosControversia = puntos.filter((p) => {
  const v = votacionesPorPunto[p.id];
  return v && v.length > 0 && !p.unanimidad && (p.resultado === "aprobado" || p.resultado === "rechazado");
});

// Municipio
let municipioSlug   = "";
let municipioNombre = pleno.municipio ?? "San Sebastián";
let partidoGobierno: string | null = null;
if (meta?.municipio_id) {
  try {
    const { data: muni } = await supabase
      .from("municipios")
      .select("slug, nombre, partido_gobierno")
      .eq("id", meta.municipio_id)
      .single();
    municipioSlug   = muni?.slug   ?? "";
    municipioNombre = muni?.nombre ?? municipioNombre;
    partidoGobierno = muni?.partido_gobierno ?? null;
  } catch {}
}

function partyMatchesGovernment(sigla: string, gobierno: string | null | undefined) {
  if (!sigla || !gobierno) return false;
  const left = sigla.toUpperCase().trim();
  const right = gobierno.toUpperCase().trim();
  return left === right || left.includes(right) || right.includes(left);
}

const governmentSiglas = new Set(
  composicion
    .filter((item) => partyMatchesGovernment(item.sigla, partidoGobierno))
    .map((item) => item.sigla)
);

const proposalSummary = {
  gobierno: { total: 0, aprobadas: 0, rechazadas: 0 },
  oposicion: { total: 0, aprobadas: 0, rechazadas: 0 },
};

const puntosEnriquecidos = puntos.map((p) => {
  const extra = puntoExtraById.get(p.id);
  const proponente = extra?.proponente ?? null;
  const bloque = proponente
    ? (governmentSiglas.has(proponente) ? "gobierno" : "oposicion")
    : "sin_clasificar";

  if (proponente && bloque !== "sin_clasificar") {
    proposalSummary[bloque].total += 1;
    if (p.resultado === "aprobado") proposalSummary[bloque].aprobadas += 1;
    if (p.resultado === "rechazado") proposalSummary[bloque].rechazadas += 1;
  }

  return {
    ...p,
    relevanciaSocial: extra?.relevancia ?? p.relevancia_social ?? 0,
    proponente,
    bloque,
  };
});

const puntosClave = puntosEnriquecidos
  .filter((p) => p.tipo !== "dar_cuenta")
  .sort((a, b) =>
    b.relevanciaSocial - a.relevanciaSocial ||
    Number(Boolean(votacionesPorPunto[b.id])) - Number(Boolean(votacionesPorPunto[a.id])) ||
    a.numero - b.numero
  )
  .slice(0, 4);

const puntosMasDivididos = puntosEnriquecidos
  .filter((p) => {
    const votos = votacionesPorPunto[p.id] ?? [];
    return votos.length > 0 && !p.unanimidad;
  })
  .sort((a, b) =>
    b.relevanciaSocial - a.relevanciaSocial ||
    (b.resultado === "rechazado" ? 1 : 0) - (a.resultado === "rechazado" ? 1 : 0) ||
    a.numero - b.numero
  )
  .slice(0, 4);

const proposalCards = [
  {
    key: "gobierno",
    label: "Propuestas del gobierno",
    data: proposalSummary.gobierno,
    tone: "acta-proposal-card--government",
  },
  {
    key: "oposicion",
    label: "Propuestas de la oposicion",
    data: proposalSummary.oposicion,
    tone: "acta-proposal-card--opposition",
  },
];

const blockLabel = (value: string) => {
  if (value === "gobierno") return "Gobierno";
  if (value === "oposicion") return "Oposicion";
  return "Sin clasificar";
};

// Descripción fallback cuando no hay resumen_ia
function describir(p: any): string | null {
  if (p.resumen_ia) return p.resumen_ia;
  const tipo: Record<string, string> = {
    aprobacion_definitiva:     "Aprobación definitiva",
    aprobacion_inicial:        "Aprobación inicial",
    proposicion_normativa:     "Proposición normativa",
    declaracion_institucional: "Declaración institucional",
    mocion:                    "Moción",
    interpelacion:             "Interpelación",
    pregunta_oral:             "Pregunta oral",
    dar_cuenta:                "El pleno toma conocimiento",
    otro:                      "Trámite",
  };
  const cat: Record<string, string> = {
    urbanismo: "urbanismo", vivienda: "vivienda", hacienda: "hacienda",
    medio_ambiente: "medio ambiente", servicios_sociales: "servicios sociales",
    movilidad: "movilidad", cultura: "cultura", derechos: "derechos",
    gobernanza: "gobernanza", seguridad: "seguridad", educacion: "educación",
  };
  const tipoStr = tipo[p.tipo] ?? "Punto";
  const catStr  = cat[p.categoria] ? ` en materia de ${cat[p.categoria]}` : "";
  const resStr  =
    p.resultado === "aprobado"
      ? p.unanimidad ? " — aprobado por unanimidad." : " — aprobado."
      : p.resultado === "rechazado" ? " — rechazado."
      : p.resultado === "enterado"  ? "."
      : ".";
  return `${tipoStr}${catStr}${resStr}`;
}

// Fechas
const fecha = new Date(pleno.fecha + "T12:00:00");
const fechaLarga = fecha.toLocaleDateString("es-ES", {
  weekday: "long", day: "numeric", month: "long", year: "numeric",
});
const fechaCorta = fecha.toLocaleDateString("es-ES", {
  day: "numeric", month: "short", year: "numeric",
});

// Grupos de puntos
const puntosResolutivos  = puntos.filter((p) => !p.es_urgencia && !["dar_cuenta","otro"].includes(p.tipo));
const puntosInformativos = puntos.filter((p) => !p.es_urgencia &&  ["dar_cuenta","otro"].includes(p.tipo));
const puntosUrgentes     = puntos.filter((p) => p.es_urgencia);
const puntosOrdenDelDia  = [...puntosUrgentes, ...puntosResolutivos];
---

<Base
  title={`Pleno nº ${pleno.numero_acta} · ${fechaCorta} · ${municipioNombre}`}
  description={`Pleno municipal de ${municipioNombre} nº ${pleno.numero_acta}, ${fechaLarga}. ${puntos.length} puntos del orden del día.`}
>

  <!-- ── BREADCRUMB ─────────────────────────────────────────────────────── -->
  <nav class="breadcrumb" aria-label="Ruta">
    <a href="/">Inicio</a>
    <span class="breadcrumb-sep">/</span>
    {municipioSlug
      ? <a href={`/ciudad/${municipioSlug}`}>{municipioNombre}</a>
      : <span>{municipioNombre}</span>}
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">Pleno nº {pleno.numero_acta}</span>
  </nav>

  <!-- ── PLENO HEADER ───────────────────────────────────────────────────── -->
  <div class="pleno-header">
    <div class="pleno-header-kicker">
      <span>{municipioNombre} · Pleno nº {pleno.numero_acta}</span>
      <span class:list={["badge-sesion", pleno.tipo_sesion === "extraordinaria" ? "badge-sesion-ext" : ""]}>
        Sesión {pleno.tipo_sesion ?? "ordinaria"}
      </span>
    </div>
    <h1 class="pleno-header-title">{fechaLarga}</h1>
    <div class="pleno-header-meta">
      {meta?.alcalde_nombre && (
        <div class="pleno-header-meta-item">
          <span class="pleno-header-meta-label">Preside</span>
          <span class="pleno-header-meta-val">{meta.alcalde_nombre}</span>
        </div>
      )}
      {meta?.hora_inicio && (
        <div class="pleno-header-meta-item">
          <span class="pleno-header-meta-label">Inicio</span>
          <span class="pleno-header-meta-val">{String(meta.hora_inicio).slice(0, 5)} h</span>
        </div>
      )}
      {(meta?.n_asistentes ?? 0) > 0 && (
        <div class="pleno-header-meta-item">
          <span class="pleno-header-meta-val">{meta!.n_asistentes} concejales</span>
          {(meta?.n_ausentes ?? 0) > 0 && (
            <span class="pleno-header-meta-label">· {meta!.n_ausentes} ausentes</span>
          )}
        </div>
      )}
      {meta?.url_pdf_original && (
        <a href={meta.url_pdf_original} target="_blank" rel="noopener noreferrer" class="pleno-pdf-link">
          ↓ Descargar acta en PDF
        </a>
      )}
    </div>
  </div>

  <!-- ── METRICS GRID ───────────────────────────────────────────────────── -->
  <div class="metrics-grid">
    <div class="metric-cell">
      <div class="metric-val">{pleno.total_puntos ?? puntos.length}</div>
      <div class="metric-label">Puntos</div>
    </div>
    <div class="metric-cell">
      <div class="metric-val metric-green">{pleno.aprobados ?? 0}</div>
      <div class="metric-label">Aprobados</div>
    </div>
    <div class="metric-cell">
      <div class="metric-val metric-red">{pleno.rechazados ?? 0}</div>
      <div class="metric-label">Rechazados</div>
    </div>
    <div class="metric-cell">
      <div class="metric-val">{pleno.unanimes ?? 0}</div>
      <div class="metric-label">Unanimidad</div>
    </div>
    <div class="metric-cell">
      <div class:list={["metric-val", puntosControversia.length > 0 ? "metric-amber" : ""]}>
        {puntosControversia.length}
      </div>
      <div class="metric-label">Polémicos</div>
    </div>
    <div class="metric-cell">
      <div class="metric-val">{meta?.n_asistentes ?? "—"}</div>
      <div class="metric-label">Concejales</div>
    </div>
  </div>

  <section class="acta-dashboard">
    <section class="acta-dashboard-panel acta-dashboard-panel--wide">
      <div class="acta-dashboard-head">
        <p class="acta-dashboard-kicker">Puntos clave</p>
        <h2 class="acta-dashboard-title">Lo mas relevante de esta sesion</h2>
      </div>

      {puntosClave.length > 0 ? (
        <div class="acta-featured-grid">
          {puntosClave.map((p) => (
            <article class="acta-featured-card">
              <div class="acta-featured-top">
                <span class="acta-featured-number">Punto {p.numero}</span>
                <span class="acta-featured-relevance">Relevancia {p.relevanciaSocial}/5</span>
              </div>
              <p class="acta-featured-title">{p.titulo}</p>
              <div class="acta-featured-tags">
                {p.categoria && p.categoria !== "otro" && (
                  <span class:list={["badge", `badge-${p.categoria}`]}>
                    {CATEGORIAS[p.categoria] ?? p.categoria}
                  </span>
                )}
                {p.proponente && (
                  <span class:list={["acta-block-pill", `acta-block-pill--${p.bloque}`]}>
                    {blockLabel(p.bloque)} · {p.proponente}
                  </span>
                )}
              </div>
              <p class="acta-featured-summary">{describir(p)}</p>
              <div class="acta-featured-footer">
                <span class:list={["resultado-pill", p.resultado]}>
                  <span class="pill-dot" />
                  {RESULTADO_LABEL[p.resultado] ?? p.resultado}
                </span>
                {votacionesPorPunto[p.id] && !p.unanimidad && (
                  <span class="acta-featured-conflict">Votacion dividida</span>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="empty-state compact-empty">Todavía no hay puntos destacados para esta sesión.</p>
      )}
    </section>

    <section class="acta-dashboard-panel">
      <div class="acta-dashboard-head">
        <p class="acta-dashboard-kicker">Impulso politico</p>
        <h2 class="acta-dashboard-title">Quien propone y que consigue aprobar</h2>
      </div>

      {(proposalSummary.gobierno.total > 0 || proposalSummary.oposicion.total > 0) ? (
        <div class="acta-proposal-grid">
          {proposalCards.map((item) => {
            const successShare = item.data.total > 0 ? item.data.aprobadas / item.data.total : 0;
            return (
              <article class:list={["acta-proposal-card", item.tone]}>
                <p class="acta-proposal-label">{item.label}</p>
                <div class="acta-proposal-value-row">
                  <span class="acta-proposal-value">{item.data.aprobadas}</span>
                  <span class="acta-proposal-note">de {item.data.total}</span>
                </div>
                <div class="acta-proposal-track">
                  <div class="acta-proposal-fill" style={`width:${Math.max(successShare * 100, item.data.total > 0 ? 10 : 0)}%`} />
                </div>
                <p class="acta-proposal-foot">
                  {Math.round(successShare * 100)}% de exito
                  {item.data.rechazadas > 0 ? ` · ${item.data.rechazadas} rechazadas` : ""}
                </p>
              </article>
            );
          })}
        </div>
      ) : (
        <p class="empty-state compact-empty">Aún no hay suficientes grupos proponentes identificados en esta acta.</p>
      )}
    </section>

    <section class="acta-dashboard-panel">
      <div class="acta-dashboard-head">
        <p class="acta-dashboard-kicker">Conflicto</p>
        <h2 class="acta-dashboard-title">Donde se partio mas el pleno</h2>
      </div>

      {puntosMasDivididos.length > 0 ? (
        <div class="acta-conflict-list">
          {puntosMasDivididos.map((p) => (
            <article class="acta-conflict-card">
              <div class="acta-conflict-top">
                <span class="acta-conflict-point">Punto {p.numero}</span>
                {p.categoria && p.categoria !== "otro" && (
                  <span class:list={["badge", `badge-${p.categoria}`]}>
                    {CATEGORIAS[p.categoria] ?? p.categoria}
                  </span>
                )}
              </div>
              <p class="acta-conflict-title">{p.titulo}</p>
              <div class="acta-conflict-meta">
                <span class:list={["resultado-pill", p.resultado]}>
                  <span class="pill-dot" />
                  {RESULTADO_LABEL[p.resultado] ?? p.resultado}
                </span>
                <span class="acta-conflict-relevance">Relevancia {p.relevanciaSocial}/5</span>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="empty-state compact-empty">Esta sesión no deja suficientes votaciones divididas para destacarlas aquí.</p>
      )}
    </section>
  </section>

  <!-- ── PAGE GRID ──────────────────────────────────────────────────────── -->
  <div class="page-grid">

    <!-- MAIN -->
    <div>
      <!-- Section label -->
      <div class="section-label-rule">
        Orden del día — {puntosOrdenDelDia.length} {puntosOrdenDelDia.length === 1 ? "punto" : "puntos"}
      </div>

      {puntos.length === 0 ? (
        <p class="empty-state">Los puntos del orden del día se están procesando.</p>
      ) : (
        <div class="punto-list">

          {/* Urgencias */}
          {puntosUrgentes.map((p) => {
            const votos = votacionesPorPunto[p.id] ?? [];
            const tieneVotos = votos.length > 0;
            const esPolemico = tieneVotos && !p.unanimidad && (p.resultado === "aprobado" || p.resultado === "rechazado");
            const votosProps = votos.map((v: any) => ({
              sigla: v.siglas, color: v.color_hex,
              a_favor: v.votos_favor, en_contra: v.votos_contra, abstencion: v.abstenciones,
            }));
            return (
              <article class="punto-card resultado-urgencia">
                <div class="punto-inner">
                  <div class="punto-top">
                    <span class="punto-num">{p.numero}.</span>
                    <span class="badge badge-amber-urgencia">Urgencia</span>
                    {p.categoria && p.categoria !== "otro" && (
                      <span class:list={["badge", `badge-${p.categoria}`]}>
                        {CATEGORIAS[p.categoria] ?? p.categoria}
                      </span>
                    )}
                    {p.tipo && p.tipo !== "otro" && (
                      <span class="badge badge-tipo">{TIPO_LABEL[p.tipo] ?? p.tipo}</span>
                    )}
                    {esPolemico && <span class="votacion-dividida-tag">Votación dividida</span>}
                  </div>
                  <p class="punto-titulo">{p.titulo}</p>
                  {describir(p) && <p class="punto-summary">{describir(p)}</p>}
                  <div class="resultado-row">
                    <span class:list={["resultado-pill", p.resultado]}>
                      <span class="pill-dot" />
                      {p.resultado === "aprobado" ? "Aprobado"
                        : p.resultado === "rechazado" ? "Rechazado"
                        : p.resultado === "enterado" ? "Enterado"
                        : RESULTADO_LABEL[p.resultado] ?? p.resultado}
                    </span>
                  </div>
                  {tieneVotos && (
                    <VotacionToggle client:load votos={votosProps} />
                  )}
                </div>
              </article>
            );
          })}

          {/* Parte resolutiva */}
          {puntosResolutivos.map((p) => {
            const votos = votacionesPorPunto[p.id] ?? [];
            const tieneVotos = votos.length > 0;
            const esPolemico = tieneVotos && !p.unanimidad && (p.resultado === "aprobado" || p.resultado === "rechazado");
            const votosProps = votos.map((v: any) => ({
              sigla: v.siglas, color: v.color_hex,
              a_favor: v.votos_favor, en_contra: v.votos_contra, abstencion: v.abstenciones,
            }));
            return (
              <article class:list={["punto-card", `resultado-${p.resultado}`]}>
                <div class="punto-inner">
                  <div class="punto-top">
                    <span class="punto-num">{p.numero}.</span>
                    {p.categoria && p.categoria !== "otro" && (
                      <span class:list={["badge", `badge-${p.categoria}`]}>
                        {CATEGORIAS[p.categoria] ?? p.categoria}
                      </span>
                    )}
                    {p.tipo && p.tipo !== "otro" && (
                      <span class="badge badge-tipo">{TIPO_LABEL[p.tipo] ?? p.tipo}</span>
                    )}
                    {esPolemico && <span class="votacion-dividida-tag">Votación dividida</span>}
                  </div>
                  <p class="punto-titulo">{p.titulo}</p>
                  {describir(p) && <p class="punto-summary">{describir(p)}</p>}
                  <div class="resultado-row">
                    <span class:list={["resultado-pill", p.resultado]}>
                      <span class="pill-dot" />
                      {p.resultado === "aprobado" ? (p.unanimidad ? "Aprobado · unanimidad" : "Aprobado")
                        : p.resultado === "rechazado" ? "Rechazado"
                        : p.resultado === "enterado" ? "Enterado"
                        : RESULTADO_LABEL[p.resultado] ?? p.resultado}
                    </span>
                  </div>
                  {tieneVotos && (
                    <VotacionToggle client:load votos={votosProps} />
                  )}
                </div>
              </article>
            );
          })}

        </div>
      )}

      <!-- Informes y comunicaciones (collapsible) -->
      {puntosInformativos.length > 0 && (
        <div class="informes-section">
          <button class="informes-toggle-btn" id="informes-toggle">
            Informes y comunicaciones ({puntosInformativos.length})
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="informes-list" id="informes-list" hidden>
            {puntosInformativos.map((p) => (
              <div class="informe-card">
                <div class="informe-header">
                  <span class="informe-num">{p.numero}.</span>
                  <span class="informe-titulo">{p.titulo}</span>
                </div>
                {describir(p) && <p class="informe-summary">{describir(p)}</p>}
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Bottom nav -->
      <div class="pleno-bottom-nav">
        {municipioSlug
          ? <a href={`/ciudad/${municipioSlug}`} class="btn-back">← Todas las actas</a>
          : <a href="/actas" class="btn-back">← Todas las actas</a>}
        {meta?.url_pdf_original
          ? <a href={meta.url_pdf_original} target="_blank" rel="noopener noreferrer" class="btn-pdf">↓ Acta en PDF</a>
          : <span />}
      </div>
    </div>

    <!-- SIDEBAR -->
    <aside class="sidebar">

      <!-- Composición del pleno -->
      {composicion.length > 0 && (
        <div class="sidebar-card">
          <div class="sidebar-section-label">Composición del pleno</div>
          <ParlamentArc client:load composicion={composicion} total={totalConcejales} />
          <div class="composicion-total">
            <strong>{totalConcejales}</strong> concejales · <strong>{composicion.length}</strong> partidos
          </div>
        </div>
      )}

      <!-- Asistencia por partido -->
      {asistenciaPartidos.length > 0 && (
        <div class="sidebar-card">
          <div class="sidebar-section-label">Asistencia al pleno</div>
          <AsistenciaWidget client:load asistencia={asistenciaPartidos} />
        </div>
      )}

      <!-- Newsletter CTA -->
      <div class="newsletter-cta">
        <div class="newsletter-cta-title">Recibe las actas</div>
        <p class="newsletter-cta-desc">Cada pleno, en tu bandeja. Resumen claro, sin ruido.</p>
        <a href="/newsletter" class="newsletter-cta-btn">Suscribirse →</a>
      </div>

    </aside>

  </div>

</Base>

