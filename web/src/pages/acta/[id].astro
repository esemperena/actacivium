---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import { getPleno, getPuntosPleno, getVotacionesPunto, supabase,
         CATEGORIAS, TIPO_LABEL, RESULTADO_LABEL } from '../../lib/supabase';

const { id } = Astro.params;
const pleno = await getPleno(id!);
if (!pleno) return Astro.redirect("/actas");

const [puntos, { data: meta }] = await Promise.all([
  getPuntosPleno(id!),
  supabase
    .from("plenos")
    .select("url_pdf_original, n_asistentes, n_ausentes, alcalde_nombre, secretaria_nombre, hora_inicio, hora_fin, municipio_id")
    .eq("id", id!)
    .single(),
]);

// Votaciones para todos los puntos
const votacionesPorPunto: Record<string, any[]> = {};
await Promise.all(
  puntos.map(async (p) => {
    const v = await getVotacionesPunto(p.id);
    if (v.length > 0) votacionesPorPunto[p.id] = v;
  })
);

// Resumen por partido acumulado del pleno
const partidoMap: Record<string, { siglas: string; partido: string; color_hex: string; favor: number; contra: number; abstenciones: number; nPuntos: number }> = {};
for (const votos of Object.values(votacionesPorPunto)) {
  for (const v of votos) {
    if (!partidoMap[v.siglas]) {
      partidoMap[v.siglas] = { siglas: v.siglas, partido: v.partido, color_hex: v.color_hex, favor: 0, contra: 0, abstenciones: 0, nPuntos: 0 };
    }
    partidoMap[v.siglas].favor        += v.votos_favor;
    partidoMap[v.siglas].contra       += v.votos_contra;
    partidoMap[v.siglas].abstenciones += v.abstenciones;
    partidoMap[v.siglas].nPuntos++;
  }
}
const resumenPartidos = Object.values(partidoMap).sort((a, b) => (b.favor + b.contra + b.abstenciones) - (a.favor + a.contra + a.abstenciones));

// Inferir concejales por partido: máximo votos en cualquier punto individual
const concejalesPorPartido: Record<string, number> = {};
for (const votos of Object.values(votacionesPorPunto)) {
  for (const v of votos) {
    const total = v.votos_favor + v.votos_contra + v.abstenciones;
    if (!concejalesPorPartido[v.siglas] || concejalesPorPartido[v.siglas] < total) {
      concejalesPorPartido[v.siglas] = total;
    }
  }
}
const maxConcejales = Math.max(...Object.values(concejalesPorPartido), 1);
const concejalesOrdenados = Object.entries(concejalesPorPartido).sort((a, b) => b[1] - a[1]);

// Puntos polémicos (para stat card)
const puntosControversia = puntos.filter((p) => {
  const v = votacionesPorPunto[p.id];
  return v && v.length > 0 && !p.unanimidad && (p.resultado === "aprobado" || p.resultado === "rechazado");
});

// Municipio
let municipioSlug   = "";
let municipioNombre = pleno.municipio ?? "San Sebastián";
if (meta?.municipio_id) {
  try {
    const { data: muni } = await supabase
      .from("municipios")
      .select("slug, nombre")
      .eq("id", meta.municipio_id)
      .single();
    municipioSlug   = muni?.slug   ?? "";
    municipioNombre = muni?.nombre ?? municipioNombre;
  } catch {}
}

// Fechas
const fecha = new Date(pleno.fecha + "T12:00:00");
const fechaLarga = fecha.toLocaleDateString("es-ES", {
  weekday: "long", day: "numeric", month: "long", year: "numeric",
});
const fechaCorta = fecha.toLocaleDateString("es-ES", {
  day: "numeric", month: "short", year: "numeric",
});

// Categorías únicas
const categorias = [...new Set(
  puntos.map((p) => p.categoria).filter((c) => c && c !== "otro")
)];

// Grupos de puntos
const puntosUrgentes     = puntos.filter((p) => p.es_urgencia);
const puntosResolutivos  = puntos.filter((p) => !p.es_urgencia && !["dar_cuenta","otro"].includes(p.tipo));
const puntosInformativos = puntos.filter((p) => !p.es_urgencia &&  ["dar_cuenta","otro"].includes(p.tipo));
---

<Base
  title={`Pleno nº ${pleno.numero_acta} · ${fechaCorta} · ${municipioNombre}`}
  description={`Pleno municipal de ${municipioNombre} nº ${pleno.numero_acta}, ${fechaLarga}. ${puntos.length} puntos del orden del día.`}
>

  <!-- ── MIGAS ───────────────────────────────────────────────────────────── -->
  <nav class="flex items-center gap-2 text-xs text-[var(--color-ink-muted)] mb-6 flex-wrap">
    <a href="/" class="hover:underline">Inicio</a>
    <span>/</span>
    {municipioSlug
      ? <a href={`/ciudad/${municipioSlug}`} class="hover:underline">{municipioNombre}</a>
      : <span>{municipioNombre}</span>}
    <span>/</span>
    <span class="text-[var(--color-ink)] font-medium">Pleno nº {pleno.numero_acta}</span>
  </nav>

  <!-- ── CABECERA ────────────────────────────────────────────────────────── -->
  <header class="mb-8 pb-8 border-b-2 border-[var(--color-ink)]">
    <div class="flex flex-wrap items-center gap-3 mb-3">
      <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-ink-muted)]">
        {municipioNombre} · Pleno nº {pleno.numero_acta}
      </span>
      <span class:list={[
        "badge",
        pleno.tipo_sesion === "extraordinaria"
          ? "bg-amber-100 text-amber-800"
          : "bg-[var(--color-accent-light)] text-[var(--color-accent)]",
      ]}>
        Sesión {pleno.tipo_sesion}
      </span>
    </div>

    <h1 class="headline-xl mb-4" style="text-transform: capitalize;">{fechaLarga}</h1>

    {pleno.resumen_ia && (
      <p class="text-base text-[var(--color-ink-muted)] leading-relaxed border-l-4 border-[var(--color-accent)] pl-4 max-w-2xl mb-4">
        {pleno.resumen_ia}
      </p>
    )}

    <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-[var(--color-ink-muted)]">
      {meta?.alcalde_nombre && <span>Preside: <strong class="text-[var(--color-ink)]">{meta.alcalde_nombre}</strong></span>}
      {meta?.hora_inicio && <span>Inicio: <strong class="text-[var(--color-ink)]">{String(meta.hora_inicio).slice(0,5)} h</strong></span>}
      {(meta?.n_asistentes ?? 0) > 0 && (
        <span>
          Asistencia: <strong class="text-[var(--color-ink)]">{meta!.n_asistentes} concejales</strong>
          {(meta?.n_ausentes ?? 0) > 0 && <span> · {meta!.n_ausentes} ausentes</span>}
        </span>
      )}
      {meta?.url_pdf_original && (
        <a href={meta.url_pdf_original} target="_blank" rel="noopener noreferrer"
           class="ml-auto font-semibold text-[var(--color-accent)] hover:underline flex items-center gap-1">
          ↓ Descargar acta en PDF
        </a>
      )}
    </div>
  </header>

  <!-- ── STATS ──────────────────────────────────────────────────────────── -->
  <section class="mb-8">
    <div class="grid grid-cols-3 sm:grid-cols-6 border border-[var(--color-border)] divide-x divide-y sm:divide-y-0 divide-[var(--color-border)]">
      {[
        { label: "Puntos",      value: pleno.total_puntos,         cls: "" },
        { label: "Aprobados",   value: pleno.aprobados,            cls: "text-[var(--color-green)]" },
        { label: "Rechazados",  value: pleno.rechazados,           cls: "text-[var(--color-red)]" },
        { label: "Unanimidad",  value: pleno.unanimes,             cls: "" },
        { label: "Polémicos",   value: puntosControversia.length,  cls: puntosControversia.length > 0 ? "text-[var(--color-amber)]" : "" },
        { label: "Concejales",  value: meta?.n_asistentes ?? "—",  cls: "" },
      ].map(({ label, value, cls }) => (
        <div class="text-center py-5 px-2 bg-white">
          <p class:list={["font-serif font-bold text-3xl", cls]}>{value}</p>
          <p class="text-[10px] uppercase tracking-widest text-[var(--color-ink-muted)] mt-1">{label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── COMPOSICIÓN DEL PLENO ─────────────────────────────────────────── -->
  {concejalesOrdenados.length > 0 && (
    <section class="mb-10">
      <div class="section-rule mb-4">
        <span class="text-xs font-bold uppercase tracking-widest">Composición del pleno</span>
      </div>

      <div class="bg-white border border-[var(--color-border)] p-5">
        <div class="space-y-3 mb-4">
          {concejalesOrdenados.map(([siglas, n]) => {
            const p = resumenPartidos.find(r => r.siglas === siglas);
            if (!p) return null;
            const barPct = Math.round((n / maxConcejales) * 100);
            const totalVotos = p.favor + p.contra + p.abstenciones;
            const pctFavor  = totalVotos > 0 ? (p.favor  / totalVotos) * 100 : 0;
            const pctContra = totalVotos > 0 ? (p.contra / totalVotos) * 100 : 0;
            const pctAbst   = totalVotos > 0 ? (p.abstenciones / totalVotos) * 100 : 0;
            const comportamiento =
              totalVotos === 0    ? null :
              pctFavor  === 100   ? "Siempre a favor" :
              pctContra === 100   ? "Siempre en contra" :
              pctAbst   >= 80     ? "Mayoritariamente abstención" :
              pctFavor  >= 60     ? `${Math.round(pctFavor)}% a favor` :
              pctContra >= 60     ? `${Math.round(pctContra)}% en contra` :
                                    `${Math.round(pctFavor)}% a favor`;
            const compColor =
              !comportamiento         ? "" :
              pctFavor  > pctContra   ? "text-[var(--color-green)]" :
              pctContra > pctFavor    ? "text-[var(--color-red)]"   :
                                        "text-[var(--color-amber)]";
            return (
              <div class="flex items-center gap-3">
                <div class="w-24 sm:w-32 shrink-0 flex items-center gap-2 min-w-0">
                  <span class="w-2.5 h-2.5 rounded-full shrink-0" style={`background: ${p.color_hex}`} />
                  <span class="text-sm font-semibold truncate" title={p.partido}>{siglas}</span>
                </div>
                <div class="flex-1 h-4 bg-[var(--color-bg)] rounded-sm overflow-hidden">
                  <div class="h-full flex rounded-sm overflow-hidden" style={`width: ${barPct}%`}>
                    {pctFavor  > 0 && <div style={`flex: ${pctFavor};  background: var(--color-green);`} class="h-full" />}
                    {pctContra > 0 && <div style={`flex: ${pctContra}; background: var(--color-red);`}   class="h-full" />}
                    {pctAbst   > 0 && <div style={`flex: ${pctAbst};   background: var(--color-amber);`} class="h-full" />}
                    {totalVotos === 0 && <div style={`background: ${p.color_hex}; opacity: 0.25;`} class="h-full flex-1" />}
                  </div>
                </div>
                <span class="text-sm font-bold w-5 text-right shrink-0">{n}</span>
                {comportamiento && (
                  <span class:list={["text-[10px] hidden sm:block w-36 shrink-0", compColor]}>
                    {comportamiento}
                  </span>
                )}
              </div>
            );
          })}
        </div>

        <div class="pt-3 border-t border-[var(--color-border)] flex flex-wrap items-center gap-x-6 gap-y-1 text-xs text-[var(--color-ink-muted)]">
          {(meta?.n_asistentes ?? 0) > 0 && (
            <span><strong class="text-[var(--color-ink)]">{meta!.n_asistentes}</strong> concejales presentes</span>
          )}
          <span><strong class="text-[var(--color-ink)]">{concejalesOrdenados.length}</strong> {concejalesOrdenados.length === 1 ? "partido" : "partidos"} con votaciones</span>
          <span class="ml-auto hidden sm:flex items-center gap-3 text-[9px]">
            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm" style="background:var(--color-green)"/>A favor</span>
            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm" style="background:var(--color-red)"/>En contra</span>
            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm" style="background:var(--color-amber)"/>Abstención</span>
          </span>
        </div>
      </div>
    </section>
  )}

  <!-- ── FILTRO POR TEMAS ───────────────────────────────────────────────── -->
  {categorias.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-10 items-center">
      {categorias.map((cat) => (
        <button
          data-filter-cat={cat}
          class:list={["cat-btn badge hover:opacity-75 transition-opacity cursor-pointer", `badge-${cat}`]}
        >
          {CATEGORIAS[cat] ?? cat}
        </button>
      ))}
      <button id="cat-reset" hidden class="badge bg-[var(--color-bg)] text-[var(--color-ink-muted)] hover:opacity-75 transition-opacity cursor-pointer">
        × Limpiar filtro
      </button>
    </div>
  )}

  <!-- ── ORDEN DEL DÍA ──────────────────────────────────────────────────── -->
  <section class="mb-10">
    <div class="section-rule mb-6">
      <span class="text-xs font-bold uppercase tracking-widest">
        Orden del día — {puntos.length} {puntos.length === 1 ? "punto" : "puntos"}
      </span>
    </div>

    {puntos.length === 0 ? (
      <p class="text-[var(--color-ink-muted)] text-sm py-12 text-center border border-dashed border-[var(--color-border)]">
        Los puntos del orden del día se están procesando.
      </p>
    ) : (
      <div class="space-y-3">

        <!-- Urgencias -->
        {puntosUrgentes.map((p) => {
          const votos = votacionesPorPunto[p.id] ?? [];
          const tieneVotos = votos.length > 0;
          const totFavor  = votos.reduce((s: number, v: any) => s + v.votos_favor,  0);
          const totContra = votos.reduce((s: number, v: any) => s + v.votos_contra, 0);
          const totAbst   = votos.reduce((s: number, v: any) => s + v.abstenciones, 0);
          return (
            <div class="punto-card border border-[var(--color-amber)] bg-[var(--color-amber-bg)] rounded-[var(--radius)] p-5"
                 data-cat={p.categoria ?? "otro"}>
              <div class="flex flex-wrap items-start gap-x-4 gap-y-2">
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap gap-2 mb-2">
                    <span class="badge" style="background: var(--color-amber-bg); color: var(--color-amber);">Urgencia</span>
                    {p.categoria !== "otro" && (
                      <span class:list={["badge", `badge-${p.categoria}`]}>{CATEGORIAS[p.categoria]}</span>
                    )}
                    <span class="text-[10px] border border-[var(--color-border)] rounded px-1.5 text-[var(--color-ink-muted)]">
                      {TIPO_LABEL[p.tipo] ?? p.tipo}
                    </span>
                  </div>
                  <p class="font-serif font-semibold text-base leading-snug mb-2">{p.titulo}</p>
                  {(p.resumen_ia || p.texto_completo) && (
                    <p class="text-sm text-[var(--color-ink-muted)] leading-relaxed">
                      {p.resumen_ia ?? p.texto_completo?.replace(/\s+/g, " ").trim().slice(0, 320) + (p.texto_completo?.length > 320 ? "…" : "")}
                    </p>
                  )}
                </div>
                <div class="shrink-0 text-right">
                  {p.resultado === "aprobado" && (
                    <span class="inline-block px-2 py-0.5 text-xs font-bold rounded" style="background: var(--color-green-bg); color: var(--color-green);">
                      Aprobado{p.unanimidad ? " · unanimidad" : ""}
                    </span>
                  )}
                  {p.resultado === "rechazado" && (
                    <span class="inline-block px-2 py-0.5 text-xs font-bold rounded" style="background: var(--color-red-bg); color: var(--color-red);">Rechazado</span>
                  )}
                  {!["aprobado","rechazado"].includes(p.resultado) && (
                    <span class="text-xs text-[var(--color-ink-muted)]">{RESULTADO_LABEL[p.resultado] ?? p.resultado}</span>
                  )}
                </div>
              </div>
              {tieneVotos && (
                <details class="vote-box mt-3 border-t border-[var(--color-border)] pt-3">
                  <summary class="vote-summary flex items-center gap-2 cursor-pointer list-none text-xs text-[var(--color-ink-muted)] select-none">
                    <span class="vote-chevron inline-block transition-transform">▸</span>
                    <span>Ver votación — {totFavor} a favor{totContra > 0 ? ` · ${totContra} en contra` : ""}{totAbst > 0 ? ` · ${totAbst} abstenciones` : ""}</span>
                  </summary>
                  <div class="pt-3 space-y-2">
                    {votos.map((v: any) => {
                      const total = v.votos_favor + v.votos_contra + v.abstenciones;
                      return (
                        <div class="flex items-center gap-3 text-xs">
                          <div class="flex items-center gap-1.5 w-28 shrink-0">
                            <span class="w-2 h-2 rounded-full shrink-0" style={`background: ${v.color_hex}`} />
                            <span class="font-semibold truncate">{v.siglas}</span>
                          </div>
                          <div class="flex-1 flex gap-0.5 h-5 rounded overflow-hidden bg-[var(--color-bg)]">
                            {v.votos_favor  > 0 && <div class="flex items-center justify-center text-[10px] font-bold text-white" style={`flex: ${v.votos_favor};  background: var(--color-green); min-width: 20px;`}>{v.votos_favor}</div>}
                            {v.votos_contra > 0 && <div class="flex items-center justify-center text-[10px] font-bold text-white" style={`flex: ${v.votos_contra}; background: var(--color-red);   min-width: 20px;`}>{v.votos_contra}</div>}
                            {v.abstenciones > 0 && <div class="flex items-center justify-center text-[10px] font-bold text-white" style={`flex: ${v.abstenciones}; background: var(--color-amber); min-width: 20px;`}>{v.abstenciones}</div>}
                            {total === 0       && <div class="flex-1 flex items-center justify-center text-[10px] text-[var(--color-ink-subtle)]">—</div>}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </details>
              )}
            </div>
          );
        })}

        <!-- Parte resolutiva -->
        {puntosResolutivos.length > 0 && (
          <div>
            {puntosUrgentes.length > 0 && (
              <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-ink-muted)] py-3 mt-1">
                — Parte resolutiva
              </p>
            )}
            {puntosResolutivos.map((p) => {
              const votos = votacionesPorPunto[p.id] ?? [];
              const esPolemico = votos.length > 0 && !p.unanimidad && (p.resultado === "aprobado" || p.resultado === "rechazado");
              const tieneVotos = votos.length > 0;
              const totFavor  = votos.reduce((s: number, v: any) => s + v.votos_favor,  0);
              const totContra = votos.reduce((s: number, v: any) => s + v.votos_contra, 0);
              const totAbst   = votos.reduce((s: number, v: any) => s + v.abstenciones, 0);
              return (
                <div
                  class:list={[
                    "punto-card border bg-white rounded-[var(--radius)] mb-3 p-4",
                    esPolemico
                      ? "border-[var(--color-amber)]"
                      : (p.relevancia_social ?? 0) >= 4
                      ? "border-l-4 border-l-[var(--color-accent)] border-[var(--color-border)]"
                      : "border-[var(--color-border)]",
                  ]}
                  data-cat={p.categoria ?? "otro"}
                >
                  <!-- Header siempre visible -->
                  <div class="flex flex-wrap items-start gap-x-3 gap-y-1">
                    <span class="font-mono text-sm font-bold text-[var(--color-ink-subtle)] w-6 shrink-0 mt-0.5">
                      {p.numero}.
                    </span>
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-wrap gap-1.5 mb-1.5">
                        {p.categoria !== "otro" && (
                          <span class:list={["badge", `badge-${p.categoria}`]}>{CATEGORIAS[p.categoria]}</span>
                        )}
                        <span class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)] border border-[var(--color-border)] rounded px-1.5 py-0.5">
                          {TIPO_LABEL[p.tipo] ?? p.tipo}
                        </span>
                        {esPolemico && (
                          <span class="text-[10px] font-semibold uppercase tracking-wide" style="color: var(--color-amber);">
                            Votación dividida
                          </span>
                        )}
                        {(p.relevancia_social ?? 0) >= 4 && (
                          <span class="flex items-center gap-1 text-[10px] text-[var(--color-accent)]">
                            {Array.from({ length: p.relevancia_social ?? 0 }).map(() => (
                              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] inline-block" />
                            ))}
                          </span>
                        )}
                      </div>
                      <!-- Título completo -->
                      <p class="font-serif font-semibold text-[0.9375rem] leading-snug mb-1.5">{p.titulo}</p>
                      <!-- Descripción siempre visible -->
                      {(p.resumen_ia || p.texto_completo) && (
                        <p class="text-sm text-[var(--color-ink-muted)] leading-relaxed">
                          {p.resumen_ia ?? p.texto_completo?.replace(/\s+/g, " ").trim().slice(0, 280) + (p.texto_completo?.length > 280 ? "…" : "")}
                        </p>
                      )}
                    </div>
                    <!-- Resultado badge -->
                    <div class="shrink-0 mt-0.5">
                      {p.resultado === "aprobado" && (
                        <span class="inline-block px-2 py-0.5 text-xs font-bold rounded" style="background: var(--color-green-bg); color: var(--color-green);">
                          Aprobado{p.unanimidad ? " · unanimidad" : ""}
                        </span>
                      )}
                      {p.resultado === "rechazado" && (
                        <span class="inline-block px-2 py-0.5 text-xs font-bold rounded" style="background: var(--color-red-bg); color: var(--color-red);">
                          Rechazado
                        </span>
                      )}
                      {!["aprobado","rechazado"].includes(p.resultado) && (
                        <span class="text-xs text-[var(--color-ink-muted)]">
                          {RESULTADO_LABEL[p.resultado] ?? p.resultado}
                        </span>
                      )}
                    </div>
                  </div>

                  <!-- Votación: expandible -->
                  {tieneVotos && (
                    <details class="vote-box mt-3 border-t border-[var(--color-border)] pt-3">
                      <summary class="vote-summary flex items-center gap-2 cursor-pointer list-none text-xs text-[var(--color-ink-muted)] select-none">
                        <span class="vote-chevron inline-block transition-transform">▸</span>
                        <span>Ver votación — {totFavor} a favor{totContra > 0 ? ` · ${totContra} en contra` : ""}{totAbst > 0 ? ` · ${totAbst} abstenciones` : ""}</span>
                      </summary>
                      <div class="pt-3 space-y-2">
                        {votos.map((v: any) => {
                          const total = v.votos_favor + v.votos_contra + v.abstenciones;
                          return (
                            <div class="flex items-center gap-3 text-xs">
                              <div class="flex items-center gap-1.5 w-28 shrink-0">
                                <span class="w-2 h-2 rounded-full shrink-0" style={`background: ${v.color_hex}`} />
                                <span class="font-semibold truncate">{v.siglas}</span>
                              </div>
                              <div class="flex-1 flex gap-0.5 h-5 rounded overflow-hidden bg-[var(--color-bg)]">
                                {v.votos_favor  > 0 && <div class="flex items-center justify-center text-[10px] font-bold text-white" style={`flex: ${v.votos_favor};  background: var(--color-green); min-width: 20px;`}>{v.votos_favor}</div>}
                                {v.votos_contra > 0 && <div class="flex items-center justify-center text-[10px] font-bold text-white" style={`flex: ${v.votos_contra}; background: var(--color-red);   min-width: 20px;`}>{v.votos_contra}</div>}
                                {v.abstenciones > 0 && <div class="flex items-center justify-center text-[10px] font-bold text-white" style={`flex: ${v.abstenciones}; background: var(--color-amber); min-width: 20px;`}>{v.abstenciones}</div>}
                                {total === 0       && <div class="flex-1 flex items-center justify-center text-[10px] text-[var(--color-ink-subtle)]">—</div>}
                              </div>
                              <div class="flex gap-2 shrink-0 text-[10px] text-right w-20 justify-end">
                                {v.votos_favor  > 0 && <span class="text-[var(--color-green)]">{v.votos_favor}✓</span>}
                                {v.votos_contra > 0 && <span class="text-[var(--color-red)]">{v.votos_contra}✗</span>}
                                {v.abstenciones > 0 && <span class="text-[var(--color-amber)]">{v.abstenciones}~</span>}
                              </div>
                            </div>
                          );
                        })}
                        {!tieneVotos && (p.resultado === "aprobado" || p.resultado === "rechazado") && (
                          <p class="text-xs text-[var(--color-ink-subtle)] italic">
                            {p.unanimidad ? "Aprobado por unanimidad." : "Sin desglose de votos disponible."}
                          </p>
                        )}
                      </div>
                    </details>
                  )}
                  {!tieneVotos && p.unanimidad && (
                    <p class="text-xs text-[var(--color-ink-subtle)] mt-2 pl-9">Aprobado por unanimidad.</p>
                  )}
                </div>
              );
            })}
          </div>
        )}

        <!-- Informes y comunicaciones -->
        {puntosInformativos.length > 0 && (
          <details id="informes-section" class="group mt-4">
            <summary class="section-rule mb-0 cursor-pointer list-none flex items-center justify-between py-2">
              <span class="text-xs font-bold uppercase tracking-widest">
                Informes y comunicaciones ({puntosInformativos.length})
              </span>
              <span class="text-xs text-[var(--color-ink-muted)] group-open:hidden">Mostrar ↓</span>
              <span class="text-xs text-[var(--color-ink-muted)] hidden group-open:block">Cerrar ↑</span>
            </summary>
            <div class="mt-3 space-y-2">
              {puntosInformativos.map((p) => (
                <div
                  class="punto-card border border-[var(--color-border)] bg-white rounded-[var(--radius)] px-5 py-3 flex items-start gap-4"
                  data-cat={p.categoria ?? "otro"}
                >
                  <span class="font-mono text-xs text-[var(--color-ink-muted)] shrink-0 mt-0.5 w-5">{p.numero}.</span>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold leading-snug mb-1">{p.titulo}</p>
                    {(p.resumen_ia || p.texto_completo) && (
                      <p class="text-xs text-[var(--color-ink-muted)] leading-relaxed mb-1.5">
                        {p.resumen_ia ?? p.texto_completo?.replace(/\s+/g, " ").trim().slice(0, 220) + (p.texto_completo?.length > 220 ? "…" : "")}
                      </p>
                    )}
                    {p.categoria && p.categoria !== "otro" && (
                      <span class:list={["badge mt-0.5", `badge-${p.categoria}`]}>{CATEGORIAS[p.categoria]}</span>
                    )}
                  </div>
                  <span class="text-xs text-[var(--color-ink-subtle)] shrink-0">Enterado</span>
                </div>
              ))}
            </div>
          </details>
        )}

      </div>
    )}
  </section>

  <!-- ── NAV INFERIOR ───────────────────────────────────────────────────── -->
  <div class="border-t border-[var(--color-border)] pt-6 flex flex-wrap justify-between items-center gap-4">
    <div class="flex items-center gap-6">
      {municipioSlug
        ? <a href={`/ciudad/${municipioSlug}`} class="text-sm font-semibold hover:underline">← Todas las actas</a>
        : <a href="/actas" class="text-sm font-semibold hover:underline">← Todas las actas</a>}
      {meta?.url_pdf_original && (
        <a href={meta.url_pdf_original} target="_blank" rel="noopener noreferrer"
           class="text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-ink)] hover:underline">
          ↓ Acta en PDF
        </a>
      )}
    </div>
    <a href="/newsletter" class="text-sm font-semibold text-[var(--color-accent)] hover:underline">
      Suscribirse a la newsletter →
    </a>
  </div>

</Base>

<style>
  .vote-box[open] .vote-chevron { transform: rotate(90deg); }
  .cat-btn.is-active { outline: 2px solid currentColor; outline-offset: 2px; }
</style>

<script>
  // ── Filtro por categoría ──────────────────────────────────────────────────
  const activeFilters = new Set<string>();
  const resetBtn = document.getElementById("cat-reset") as HTMLButtonElement | null;
  const informesSection = document.getElementById("informes-section") as HTMLDetailsElement | null;

  document.querySelectorAll<HTMLButtonElement>("[data-filter-cat]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const cat = btn.dataset.filterCat!;
      if (activeFilters.has(cat)) {
        activeFilters.delete(cat);
        btn.classList.remove("is-active");
      } else {
        activeFilters.add(cat);
        btn.classList.add("is-active");
      }
      applyFilter();
    });
  });

  resetBtn?.addEventListener("click", () => {
    activeFilters.clear();
    document.querySelectorAll<HTMLButtonElement>("[data-filter-cat]").forEach((b) => b.classList.remove("is-active"));
    applyFilter();
  });

  function applyFilter() {
    const cards = document.querySelectorAll<HTMLElement>(".punto-card");

    if (activeFilters.size === 0) {
      cards.forEach((c) => c.removeAttribute("hidden"));
      resetBtn?.setAttribute("hidden", "");
      return;
    }

    resetBtn?.removeAttribute("hidden");
    let hasInfoMatch = false;

    cards.forEach((card) => {
      const cat = card.dataset.cat ?? "";
      const matches = activeFilters.has(cat);
      if (matches) {
        card.removeAttribute("hidden");
        if (card.closest("#informes-section")) hasInfoMatch = true;
      } else {
        card.setAttribute("hidden", "");
      }
    });

    // Abrir sección de informes automáticamente si hay coincidencias
    if (informesSection && hasInfoMatch) {
      informesSection.open = true;
    }
  }

  // ── Chevron en details de votación ───────────────────────────────────────
  document.querySelectorAll<HTMLDetailsElement>(".vote-box").forEach((details) => {
    details.addEventListener("toggle", () => {
      const chevron = details.querySelector(".vote-chevron");
      if (chevron) {
        (chevron as HTMLElement).style.transform = details.open ? "rotate(90deg)" : "";
      }
    });
  });
</script>
