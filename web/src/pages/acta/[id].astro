---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import { getPleno, getPuntosPleno, supabase, CATEGORIAS } from '../../lib/supabase';

const { id } = Astro.params;
const pleno = await getPleno(id!);
if (!pleno) return Astro.redirect("/actas");

const [puntos, { data: meta }] = await Promise.all([
  getPuntosPleno(id!),
  supabase
    .from("plenos")
    .select("url_pdf_original, n_asistentes, n_ausentes, alcalde_nombre, secretaria_nombre, hora_inicio, hora_fin, texto_completo")
    .eq("id", id!)
    .single(),
]);

// ── Fecha ──
const fecha = new Date(pleno.fecha + "T12:00:00");
const fechaLarga = fecha.toLocaleDateString("es-ES", {
  weekday: "long", day: "numeric", month: "long", year: "numeric",
});
const fechaCorta = fecha.toLocaleDateString("es-ES", {
  day: "numeric", month: "short", year: "numeric",
});

// ── Puntos agrupados ──
const puntosResolutivos  = puntos.filter(p => !["dar_cuenta","otro"].includes(p.tipo));
const puntosInformativos = puntos.filter(p =>  ["dar_cuenta","otro"].includes(p.tipo));

// ── Categorías únicas ──
const categorias = [...new Set(puntos.map(p => p.categoria).filter(Boolean))];

// ── Tipo labels ──
const TIPO_LABEL: Record<string, string> = {
  dar_cuenta:               "Dar cuenta",
  aprobacion_definitiva:    "Aprobación definitiva",
  aprobacion_inicial:       "Aprobación inicial",
  proposicion_normativa:    "Proposición normativa",
  declaracion_institucional:"Declaración institucional",
  mocion:                   "Moción",
  ruego:                    "Ruego",
  pregunta_oral:            "Pregunta oral",
  interpelacion:            "Interpelación",
  otro:                     "Trámite",
};

const RESULTADO_LABEL: Record<string, string> = {
  aprobado:      "Aprobado",
  rechazado:     "Rechazado",
  enterado:      "Enterado",
  retirado:      "Retirado",
  aplazado:      "Aplazado",
  sin_votacion:  "Informativo",
};

const RESULTADO_COLOR: Record<string, string> = {
  aprobado:  "text-[#1b5e20] font-semibold",
  rechazado: "text-[#c41a1a] font-semibold",
  enterado:  "text-[var(--color-ink-muted)]",
  sin_votacion: "text-[var(--color-ink-muted)]",
};

// ── Texto del acta (primeros 2500 chars limpios) ──
const textoPreview = (meta?.texto_completo ?? "")
  .slice(0, 2500)
  .replace(/\n{3,}/g, "\n\n")
  .trim();
---

<Base
  title={`Pleno nº ${pleno.numero_acta} · ${fechaCorta} · Acta Civium`}
  description={`Acta del pleno municipal de ${pleno.municipio ?? "San Sebastián"} celebrado el ${fechaLarga}. ${puntos.length} puntos del orden del día.`}
>

  <!-- ── MIGAS ───────────────────────────────────────────────────────────── -->
  <nav class="flex items-center gap-2 text-xs text-[var(--color-ink-muted)] mb-6">
    <a href="/actas" class="hover:underline">← Actas</a>
    <span>/</span>
    <span>{pleno.municipio ?? "San Sebastián"}</span>
    <span>/</span>
    <span class="text-[var(--color-ink)] font-medium">Pleno nº {pleno.numero_acta}</span>
  </nav>

  <!-- ── CABECERA ────────────────────────────────────────────────────────── -->
  <header class="mb-8 pb-8 border-b-2 border-[var(--color-ink)]">
    <div class="flex flex-wrap items-center gap-3 mb-3">
      <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-ink-muted)]">
        {pleno.municipio ?? "San Sebastián"} · Pleno nº {pleno.numero_acta}
      </span>
      <span class:list={[
        "badge",
        pleno.tipo_sesion === "extraordinaria"
          ? "bg-amber-100 text-amber-800"
          : "bg-[var(--color-accent-light)] text-[var(--color-accent)]",
      ]}>
        Sesión {pleno.tipo_sesion}
      </span>
      {meta?.url_pdf_original && (
        <a
          href={meta.url_pdf_original}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-auto text-xs font-semibold border border-[var(--color-ink)] px-3 py-1 hover:bg-[var(--color-ink)] hover:text-white transition-colors"
        >
          PDF original ↗
        </a>
      )}
    </div>

    <h1 class="headline-xl mb-4" style="text-transform: capitalize;">
      {fechaLarga}
    </h1>

    {pleno.resumen_ia && (
      <p class="text-base text-[var(--color-ink-muted)] leading-relaxed border-l-4 border-[var(--color-accent)] pl-4 max-w-2xl">
        {pleno.resumen_ia}
      </p>
    )}
  </header>

  <!-- ── DASHBOARD DE ESTADÍSTICAS ─────────────────────────────────────── -->
  <section class="mb-8">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 border border-[var(--color-border)] divide-x divide-y sm:divide-y-0 divide-[var(--color-border)]">
      {[
        { label: "Puntos",       value: pleno.total_puntos,            extra: "" },
        { label: "Aprobados",    value: pleno.aprobados,               extra: "text-[#1b5e20]" },
        { label: "Rechazados",   value: pleno.rechazados,              extra: "text-[#c41a1a]" },
        { label: "Unanimidad",   value: pleno.unanimes,                extra: "" },
        { label: "Concejales",   value: meta?.n_asistentes ?? "—",     extra: "" },
        { label: "Ausentes",     value: meta?.n_ausentes   ?? "—",     extra: "text-[var(--color-ink-muted)]" },
      ].map(({ label, value, extra }) => (
        <div class="text-center py-5 px-2 bg-white">
          <p class:list={["font-serif text-3xl font-bold", extra]}>{value}</p>
          <p class="text-[10px] uppercase tracking-widest text-[var(--color-ink-muted)] mt-1">{label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── FICHA DEL PLENO ───────────────────────────────────────────────── -->
  <section class="mb-10">
    <div class="section-rule mb-4">
      <span class="text-xs font-bold uppercase tracking-widest">Ficha del pleno</span>
    </div>
    <dl class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-4 text-sm">
      <div>
        <dt class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)] mb-0.5">Fecha</dt>
        <dd class="font-medium" style="text-transform: capitalize;">{fechaLarga}</dd>
      </div>
      {meta?.hora_inicio && (
        <div>
          <dt class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)] mb-0.5">Hora de inicio</dt>
          <dd class="font-medium">{meta.hora_inicio.slice(0, 5)} h</dd>
        </div>
      )}
      {meta?.alcalde_nombre && (
        <div>
          <dt class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)] mb-0.5">Preside</dt>
          <dd class="font-medium">{meta.alcalde_nombre}</dd>
        </div>
      )}
      {meta?.secretaria_nombre && (
        <div>
          <dt class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)] mb-0.5">Secretaría</dt>
          <dd class="font-medium">{meta.secretaria_nombre}</dd>
        </div>
      )}
      <div>
        <dt class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)] mb-0.5">Tipo de sesión</dt>
        <dd class="font-medium" style="text-transform: capitalize;">{pleno.tipo_sesion}</dd>
      </div>
      <div>
        <dt class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)] mb-0.5">Asistencia</dt>
        <dd class="font-medium">
          {meta?.n_asistentes ? `${meta.n_asistentes} concejales` : "—"}
          {meta?.n_ausentes > 0 && (
            <span class="text-[var(--color-ink-muted)] font-normal"> · {meta.n_ausentes} ausentes</span>
          )}
        </dd>
      </div>
      {categorias.length > 0 && (
        <div class="sm:col-span-2">
          <dt class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)] mb-2">Temas tratados</dt>
          <dd class="flex flex-wrap gap-2">
            {categorias.map(cat => (
              <a
                href={`/temas/${cat}`}
                class:list={["badge hover:opacity-75 transition-opacity", `badge-${cat}`]}
              >
                {CATEGORIAS[cat] ?? cat}
              </a>
            ))}
          </dd>
        </div>
      )}
    </dl>
  </section>

  <!-- ── ORDEN DEL DÍA ─────────────────────────────────────────────────── -->
  <section class="mb-10">
    <div class="section-rule mb-6">
      <span class="text-xs font-bold uppercase tracking-widest">Orden del día — {puntos.length} puntos</span>
    </div>

    {puntos.length === 0 ? (
      <p class="text-[var(--color-ink-muted)] text-sm py-8 text-center border border-dashed border-[var(--color-border)]">
        El análisis de los puntos del orden del día está en proceso.
      </p>
    ) : (
      <div class="space-y-3">
        {puntos.map((p) => {
          const cat = CATEGORIAS[p.categoria] ?? null;
          const resColor = RESULTADO_COLOR[p.resultado] ?? "text-[var(--color-ink-muted)]";
          const resLabel = RESULTADO_LABEL[p.resultado] ?? p.resultado;
          const tipoLabel = TIPO_LABEL[p.tipo] ?? p.tipo;
          return (
            <div class:list={[
              "border border-[var(--color-border)] bg-white p-5",
              p.es_urgencia && "border-l-4 border-l-amber-500",
              (p.relevancia_social ?? 0) >= 4 && "border-l-4 border-l-[var(--color-accent)]",
            ]}>
              <div class="flex flex-wrap items-start gap-x-4 gap-y-2">
                <!-- Número -->
                <span class="font-mono text-sm font-bold text-[var(--color-ink-muted)] w-6 shrink-0 mt-0.5">
                  {p.numero}.
                </span>

                <!-- Título y badges -->
                <div class="flex-1 min-w-0">
                  <p class="font-serif font-semibold text-base leading-snug mb-2">
                    {p.titulo}
                  </p>
                  <div class="flex flex-wrap items-center gap-2">
                    {p.categoria && (
                      <span class:list={["badge", `badge-${p.categoria}`]}>
                        {CATEGORIAS[p.categoria] ?? p.categoria}
                      </span>
                    )}
                    <span class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)] border border-[var(--color-border)] px-2 py-0.5">
                      {tipoLabel}
                    </span>
                    {p.es_urgencia && (
                      <span class="badge" style="background:#fef2f2;color:#991b1b;">Urgencia</span>
                    )}
                    {(p.relevancia_social ?? 0) >= 4 && (
                      <span class="flex items-center gap-1 text-[10px] text-[var(--color-accent)]">
                        {Array.from({ length: p.relevancia_social }).map(() => (
                          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] inline-block" />
                        ))}
                        <span class="ml-0.5 uppercase tracking-wide">Alta relevancia</span>
                      </span>
                    )}
                  </div>

                  {p.resumen_ia && (
                    <p class="text-sm text-[var(--color-ink-muted)] mt-2 leading-relaxed">
                      {p.resumen_ia}
                    </p>
                  )}
                </div>

                <!-- Resultado -->
                <span class:list={["text-xs shrink-0 mt-0.5", resColor]}>
                  {resLabel}
                </span>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </section>

  <!-- ── TEXTO DEL ACTA ────────────────────────────────────────────────── -->
  {textoPreview && (
    <section class="mb-10">
      <details class="group">
        <summary class="section-rule mb-0 cursor-pointer list-none flex items-center justify-between">
          <span class="text-xs font-bold uppercase tracking-widest">Texto del acta</span>
          <span class="text-xs text-[var(--color-ink-muted)] group-open:hidden">Mostrar extracto ↓</span>
          <span class="text-xs text-[var(--color-ink-muted)] hidden group-open:block">Cerrar ↑</span>
        </summary>
        <div class="mt-4 p-5 bg-white border border-[var(--color-border)] text-sm leading-relaxed text-[var(--color-ink-muted)] whitespace-pre-wrap font-mono max-h-96 overflow-y-auto">
          {textoPreview}…
        </div>
        {meta?.url_pdf_original && (
          <div class="mt-3 text-center">
            <a
              href={meta.url_pdf_original}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs font-semibold text-[var(--color-accent)] hover:underline"
            >
              Ver el documento completo en PDF →
            </a>
          </div>
        )}
      </details>
    </section>
  )}

  <!-- ── NAVEGACIÓN ───────────────────────────────────────────────────── -->
  <div class="border-t border-[var(--color-border)] pt-6 flex justify-between items-center">
    <a href="/actas" class="text-sm font-semibold hover:underline">← Todas las actas</a>
    <a href="/newsletter" class="text-sm font-semibold text-[var(--color-accent)] hover:underline">
      Suscribirse a la newsletter →
    </a>
  </div>

</Base>
