---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import CityDashboard from '../../components/CityDashboard.astro';
import PlenoCard from '../../components/PlenoCard.astro';
import {
  getMunicipio,
  getCityDashboard,
  getPlenosByMunicipio,
  supabase,
  CATEGORIAS,
} from '../../lib/supabase';

const { slug } = Astro.params;
const municipio = await getMunicipio(slug!);
if (!municipio) return Astro.redirect("/");

const page = Number(Astro.url.searchParams.get("page") ?? 1);
const { data: plenos, count } = await getPlenosByMunicipio(municipio.id, page);
const dashboard = await getCityDashboard(municipio.id, municipio.partido_gobierno);
const totalPages = Math.ceil((count ?? 0) / 20);

let highlightsByPleno: Record<string, { titulo: string; categoria: string; resultado: string }[]> = {};

try {
  const ids = plenos.map((p) => p.id);
  if (ids.length > 0) {
    const { data: pts } = await supabase
      .from("puntos")
      .select("pleno_id, titulo, categoria, resultado, relevancia_social, tipo")
      .in("pleno_id", ids);

    const allPts = pts ?? [];
    const byRelevance: Record<string, typeof allPts> = {};
    for (const pt of allPts.filter(p => p.tipo !== "dar_cuenta" && p.titulo)) {
      if (!byRelevance[pt.pleno_id]) byRelevance[pt.pleno_id] = [];
      byRelevance[pt.pleno_id].push(pt);
    }
    highlightsByPleno = {};
    for (const [pid, pts2] of Object.entries(byRelevance)) {
      highlightsByPleno[pid] = pts2
        .sort((a, b) => (b.relevancia_social ?? 0) - (a.relevancia_social ?? 0))
        .slice(0, 3)
        .map(p => ({ titulo: p.titulo, categoria: p.categoria ?? "otro", resultado: p.resultado ?? "sin_votacion" }));
    }
  }
} catch {}

const ultimaFecha = plenos[0]?.fecha
  ? new Date(plenos[0].fecha + "T12:00:00").toLocaleDateString("es-ES", {
      day: "numeric", month: "long", year: "numeric",
    })
  : null;

const primerFecha = plenos.length > 0
  ? new Date(plenos[plenos.length - 1].fecha + "T12:00:00").toLocaleDateString("es-ES", {
      month: "long", year: "numeric",
    })
  : null;

const accentColor = municipio.color_gobierno ?? "var(--color-accent)";

const { summary, categoryStats } = dashboard;

const ciudadTitle = municipio.nombre_alt && municipio.nombre_alt !== municipio.nombre
  ? `${municipio.nombre_alt}-${municipio.nombre}`
  : municipio.nombre;

const introText = [
  `El Ayuntamiento de ${ciudadTitle}${municipio.provincia ? `, ${municipio.provincia},` : ""}`,
  municipio.n_concejales ? `cuenta con ${municipio.n_concejales} concejales` : null,
  municipio.partido_gobierno && municipio.alcalde
    ? `y su gobierno lo encabeza ${municipio.alcalde} (${municipio.partido_gobierno}).`
    : null,
  `Acta Civium analiza las actas del pleno municipal para mostrar qué se aprueba, quién vota qué y qué temas dominan el debate político local.`,
].filter(Boolean).join(" ");
---

<Base
  title={`Plenos Municipales de ${ciudadTitle}`}
  description={`Sigue los plenos del Ayuntamiento de ${ciudadTitle}: actas, votaciones, composición del pleno y temas debatidos.${municipio.alcalde ? ` Alcalde: ${municipio.alcalde} (${municipio.partido_gobierno}).` : ""}`}
>

  <!-- ── CITY CONTEXT BAR ──────────────────────────────────────────────── -->
  <div class="city-bar">
    <div class="city-bar-accent" style={`background: ${accentColor}`} />

    <div class="city-bar-name">
      <h1 class="city-bar-title">{municipio.nombre}</h1>
      {municipio.nombre_alt && municipio.nombre_alt !== municipio.nombre && (
        <span class="city-bar-alt"> · {municipio.nombre_alt}</span>
      )}
    </div>

    <div class="city-bar-sep" />

    <div class="city-bar-meta">
      <span>{municipio.provincia} · {municipio.comunidad}</span>
      {primerFecha && <><span class="city-bar-dot">·</span><span>Cobertura desde {primerFecha}</span></>}
      {ultimaFecha && <><span class="city-bar-dot">·</span><span>Último pleno: {ultimaFecha}</span></>}
    </div>

    <a href="/newsletter" class="city-bar-cta">Newsletter →</a>
  </div>

  <!-- ── METRICS GRID ──────────────────────────────────────────────────── -->
  <div class="metrics-grid">
    <div class="metric-cell">
      <div class="metric-val">{summary.totalPlenos}</div>
      <div class="metric-label">Actas analizadas</div>
    </div>
    <div class="metric-cell">
      <div class="metric-val">{summary.totalPuntos}</div>
      <div class="metric-label">Puntos tratados</div>
    </div>
    <div class="metric-cell">
      <div class="metric-val metric-val--green">{summary.totalAprobados}</div>
      <div class="metric-label">Aprobados</div>
    </div>
    <div class="metric-cell">
      <div class="metric-val metric-val--red">{summary.totalRechazados}</div>
      <div class="metric-label">Rechazados</div>
    </div>
    <div class="metric-cell">
      <div class="metric-val">{municipio.n_concejales ?? "—"}</div>
      <div class="metric-label">Concejales</div>
    </div>
    <div class="metric-cell">
      {municipio.partido_gobierno
        ? <div class="metric-val metric-val--text">{municipio.partido_gobierno}</div>
        : <div class="metric-val">—</div>
      }
      {municipio.alcalde && <div class="metric-sub">{municipio.alcalde}</div>}
      <div class="metric-label">Gobierno</div>
    </div>
  </div>

  <!-- ── DASHBOARD (Composición, Agenda, Coincidencia) ────────────────── -->
  <CityDashboard municipio={municipio} dashboard={dashboard} introText={introText} />

  <!-- ── PAGE GRID ─────────────────────────────────────────────────────── -->
  <div class="page-grid">

    <!-- Main: pleno list -->
    <div>
      <h2 class="section-label-row">
        Actas del pleno municipal de {municipio.nombre} · {count} {(count ?? 0) === 1 ? "sesión" : "sesiones"}
      </h2>

      {plenos.length === 0 ? (
        <p style="color: var(--color-ink-muted); font-size: 0.875rem; padding: 32px 0; text-align: center; border: 1px dashed var(--color-border); border-radius: var(--radius);">
          No hay actas procesadas todavía.
        </p>
      ) : (
        <>
          <div class="plenos-list">
            {plenos.map((p, i) => (
              <PlenoCard
                pleno={p}
                featured={i === 0 && page === 1}
                highlights={highlightsByPleno[p.id]}
              />
            ))}
          </div>

          {totalPages > 1 && (
            <nav class="pagination">
              {page > 1
                ? <a href={`/ciudad/${slug}?page=${page - 1}`}>← Más recientes</a>
                : <span />}
              <span class="pagination-info">Página {page} de {totalPages}</span>
              {page < totalPages
                ? <a href={`/ciudad/${slug}?page=${page + 1}`}>Anteriores →</a>
                : <span />}
            </nav>
          )}
        </>
      )}
    </div>

    <!-- Sidebar -->
    <aside class="sidebar">

      <!-- Ficha del municipio -->
      <div class="sidebar-card">
        <h2 class="sidebar-section-label">Ficha del municipio</h2>

        {municipio.alcalde && (
          <div class="ficha-row">
            <div class="ficha-dt">Alcalde/sa</div>
            <div class="ficha-dd">{municipio.alcalde}</div>
          </div>
        )}

        {municipio.partido_gobierno && (
          <div class="ficha-row">
            <div class="ficha-dt">Partido de gobierno</div>
            <div class="ficha-dd">
              {municipio.color_gobierno && (
                <span class="partido-dot" style={`background: ${municipio.color_gobierno}`} />
              )}
              {municipio.partido_gobierno}
            </div>
          </div>
        )}

        {municipio.n_concejales && (
          <div class="ficha-row">
            <div class="ficha-dt">Concejales</div>
            <div class="ficha-dd">{municipio.n_concejales}</div>
          </div>
        )}

        {municipio.poblacion && (
          <div class="ficha-row">
            <div class="ficha-dt">Población</div>
            <div class="ficha-dd">{municipio.poblacion.toLocaleString("es-ES")} hab.</div>
          </div>
        )}

        {municipio.web_oficial && (
          <a href={municipio.web_oficial} target="_blank" rel="noopener" class="ficha-link">
            Web oficial del Ayuntamiento →
          </a>
        )}
      </div>

      <!-- Temas más tratados -->
      {categoryStats.length > 0 && (
        <div class="sidebar-card">
          <h2 class="sidebar-section-label">Temas más tratados</h2>
          {categoryStats.map(({ categoria, label, total }) => (
            <div class="topic-row">
              <span class:list={["badge", `badge-${categoria}`]}>{label}</span>
              <span class="topic-count">{total} puntos</span>
            </div>
          ))}
        </div>
      )}

    </aside>
  </div>

</Base>

<style>
  /* ── City context bar ───────────────────────────────────────────────── */
  .city-bar {
    position: relative;
    display: flex;
    align-items: center;
    height: 52px;
    padding: 0 18px 0 22px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 28px;
  }
  .city-bar-accent {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    border-radius: 3px 0 0 3px;
  }
  .city-bar-name {
    display: flex;
    align-items: baseline;
    flex-shrink: 0;
    padding-right: 16px;
  }
  .city-bar-title {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  .city-bar-alt {
    font-size: 0.8125rem;
    color: var(--color-ink-muted);
  }
  .city-bar-sep {
    width: 1px;
    height: 22px;
    background: var(--color-border);
    flex-shrink: 0;
    margin-right: 16px;
  }
  .city-bar-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: var(--color-ink-subtle);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    white-space: nowrap;
  }
  .city-bar-dot { opacity: 0.4; }
  .city-bar-cta {
    margin-left: auto;
    flex-shrink: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-accent-mid);
    text-decoration: none;
    padding-left: 16px;
    transition: color 0.15s;
  }
  .city-bar-cta:hover { color: var(--color-accent); }

  /* ── Metrics grid ───────────────────────────────────────────────────── */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius) + 2px);
    overflow: hidden;
    margin-bottom: 40px;
    background: var(--color-bg-card);
  }
  .metric-cell {
    padding: 20px 12px;
    text-align: center;
    border-right: 1px solid var(--color-border);
  }
  .metric-cell:last-child { border-right: none; }
  .metric-val {
    font-family: var(--font-serif);
    font-size: 1.875rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }
  .metric-val--green { color: var(--color-green); }
  .metric-val--red   { color: var(--color-red); }
  .metric-val--text  {
    font-size: 0.9375rem;
    line-height: 1.25;
    font-family: var(--font-sans);
    font-weight: 600;
  }
  .metric-sub {
    font-size: 0.6875rem;
    color: var(--color-ink-subtle);
    margin-top: 2px;
  }
  .metric-label {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
    margin-top: 6px;
  }

  /* ── Page grid ──────────────────────────────────────────────────────── */
  .page-grid {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 48px;
    align-items: start;
  }

  /* ── Section label ──────────────────────────────────────────────────── */
  .section-label-row {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-label-row::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
    max-width: 80px;
  }

  /* ── Pleno list ─────────────────────────────────────────────────────── */
  .plenos-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* ── Pagination ─────────────────────────────────────────────────────── */
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
  }
  .pagination a {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }
  .pagination a:hover { text-decoration: underline; }
  .pagination-info { font-size: 0.75rem; color: var(--color-ink-subtle); }

  /* ── Sidebar ────────────────────────────────────────────────────────── */
  .sidebar { display: flex; flex-direction: column; gap: 28px; }

  .sidebar-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius) + 2px);
    padding: 18px 18px 16px;
  }
  .sidebar-section-label {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-border);
  }

  .ficha-row { margin-bottom: 12px; }
  .ficha-row:last-of-type { margin-bottom: 0; }
  .ficha-dt {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
    margin-bottom: 2px;
  }
  .ficha-dd {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .partido-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .ficha-link {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
    display: inline-block;
    margin-top: 14px;
    text-decoration: none;
  }
  .ficha-link:hover { text-decoration: underline; }

  .topic-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid var(--color-border);
    cursor: default;
  }
  .topic-row:last-child { border-bottom: none; }
  .topic-count {
    font-size: 0.75rem;
    color: var(--color-ink-subtle);
  }

  /* ── Responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .metrics-grid { grid-template-columns: repeat(3, 1fr); }
    .metric-cell:nth-child(3) { border-right: none; }
    .metric-cell:nth-child(4),
    .metric-cell:nth-child(5),
    .metric-cell:nth-child(6) { border-top: 1px solid var(--color-border); }
    .page-grid { grid-template-columns: 1fr 220px; gap: 32px; }
  }

  @media (max-width: 768px) {
    .city-bar { height: auto; padding: 12px 16px 12px 20px; }
    .city-bar-meta { display: none; }
    .city-bar-cta  { display: none; }
    .city-bar-sep  { display: none; }

    .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    .metric-cell:nth-child(2n) { border-right: none; }
    .metric-cell:nth-child(3) { border-right: 1px solid var(--color-border); }
    .metric-cell { border-bottom: 1px solid var(--color-border); }
    .metric-cell:nth-child(5),
    .metric-cell:nth-child(6) { border-bottom: none; }

    .page-grid { grid-template-columns: 1fr; gap: 40px; }
    .sidebar { order: -1; }
  }

  @media (max-width: 480px) {
    .metric-val { font-size: 1.5rem; }
  }
</style>
