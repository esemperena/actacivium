---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import CityDashboard from '../../components/CityDashboard.astro';
import PlenoCard from '../../components/PlenoCard.astro';
import {
  getMunicipio,
  getCityDashboard,
  getPlenosByMunicipio,
  supabase,
} from '../../lib/supabase';

const { slug } = Astro.params;
const municipio = await getMunicipio(slug!);
if (!municipio) return Astro.redirect("/");

const page = Number(Astro.url.searchParams.get("page") ?? 1);
const { data: plenos, count } = await getPlenosByMunicipio(municipio.id, page);
const dashboard = await getCityDashboard(municipio.id, municipio.partido_gobierno);
const totalPages = Math.ceil((count ?? 0) / 20);

let highlightsByPleno: Record<string, { titulo: string; categoria: string; resultado: string }[]> = {};

try {
  const ids = plenos.map((p) => p.id);
  if (ids.length > 0) {
    const { data: pts } = await supabase
      .from("puntos")
      .select("pleno_id, titulo, categoria, resultado, relevancia_social, tipo")
      .in("pleno_id", ids);

    const allPts = pts ?? [];
    const byRelevance: Record<string, typeof allPts> = {};
    for (const pt of allPts.filter(p => p.tipo !== "dar_cuenta" && p.titulo)) {
      if (!byRelevance[pt.pleno_id]) byRelevance[pt.pleno_id] = [];
      byRelevance[pt.pleno_id].push(pt);
    }
    highlightsByPleno = {};
    for (const [pid, pts2] of Object.entries(byRelevance)) {
      highlightsByPleno[pid] = pts2
        .sort((a, b) => (b.relevancia_social ?? 0) - (a.relevancia_social ?? 0))
        .slice(0, 3)
        .map(p => ({ titulo: p.titulo, categoria: p.categoria ?? "otro", resultado: p.resultado ?? "sin_votacion" }));
    }
  }
} catch {}

const ultimaFecha = plenos[0]?.fecha
  ? new Date(plenos[0].fecha + "T12:00:00").toLocaleDateString("es-ES", {
      day: "numeric", month: "long", year: "numeric",
    })
  : null;

const primerFecha = plenos.length > 0
  ? new Date(plenos[plenos.length - 1].fecha + "T12:00:00").toLocaleDateString("es-ES", {
      month: "long", year: "numeric",
    })
  : null;

const accentColor = municipio.color_gobierno ?? "var(--color-accent)";
---

<Base
  title={`${municipio.nombre} · Plenos Municipales · Acta Civium`}
  description={`Plenos municipales del Ayuntamiento de ${municipio.nombre}. ${count} actas analizadas desde una perspectiva ciudadana.`}
>

  <!-- ── CITY CONTEXT BAR ──────────────────────────────────────────────── -->
  <div class="city-bar">
    <div class="city-bar-accent" style={`background: ${accentColor}`} />

    <div class="city-bar-name">
      <span class="city-bar-title">{municipio.nombre}</span>
      {municipio.nombre_alt && municipio.nombre_alt !== municipio.nombre && (
        <span class="city-bar-alt"> · {municipio.nombre_alt}</span>
      )}
    </div>

    <div class="city-bar-sep" />

    <div class="city-bar-meta">
      <span>{municipio.provincia} · {municipio.comunidad}</span>
      {primerFecha && <><span class="city-bar-dot">·</span><span>Cobertura desde {primerFecha}</span></>}
      {ultimaFecha && <><span class="city-bar-dot">·</span><span>Último pleno: {ultimaFecha}</span></>}
    </div>

    <a href="/newsletter" class="city-bar-cta">Newsletter →</a>
  </div>

  <CityDashboard municipio={municipio} dashboard={dashboard} />

  <section>
    <div class="section-rule mb-6">
      <span class="text-xs font-bold uppercase tracking-widest">
        Archivo de actas · {count} {(count ?? 0) === 1 ? "sesión" : "sesiones"}
      </span>
    </div>

    {plenos.length === 0 ? (
      <p class="text-[var(--color-ink-muted)] text-sm py-8 text-center border border-dashed border-[var(--color-border)]">
        No hay actas procesadas todavía.
      </p>
    ) : (
      <>
        <div class="plenos-list">
          {plenos.map((p, i) => <PlenoCard pleno={p} featured={i === 0 && page === 1} highlights={highlightsByPleno[p.id]} />)}
        </div>

        {totalPages > 1 && (
          <nav class="flex justify-between items-center mt-8 pt-4 border-t border-[var(--color-border)]">
            {page > 1
              ? <a href={`/ciudad/${slug}?page=${page - 1}`} class="text-sm font-semibold hover:underline">← Más recientes</a>
              : <span />}
            <span class="text-xs text-[var(--color-ink-muted)]">Página {page} de {totalPages}</span>
            {page < totalPages
              ? <a href={`/ciudad/${slug}?page=${page + 1}`} class="text-sm font-semibold hover:underline">Anteriores →</a>
              : <span />}
          </nav>
        )}
      </>
    )}
  </section>

</Base>

<style>
  /* ── City context bar ───────────────────────────────────────────────── */
  .city-bar {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0;
    height: 52px;
    padding: 0 18px 0 22px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 28px;
  }
  .city-bar-accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    border-radius: 3px 0 0 3px;
  }
  .city-bar-name {
    display: flex;
    align-items: baseline;
    gap: 0;
    flex-shrink: 0;
    padding-right: 16px;
  }
  .city-bar-title {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  .city-bar-alt {
    font-size: 0.8125rem;
    color: var(--color-ink-muted);
  }
  .city-bar-sep {
    width: 1px;
    height: 22px;
    background: var(--color-border);
    flex-shrink: 0;
    margin-right: 16px;
  }
  .city-bar-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: var(--color-ink-subtle);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    white-space: nowrap;
  }
  .city-bar-dot { opacity: 0.4; }
  .city-bar-cta {
    margin-left: auto;
    flex-shrink: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-accent-mid);
    text-decoration: none;
    padding-left: 16px;
    transition: color 0.15s;
  }
  .city-bar-cta:hover { color: var(--color-accent); }

  /* ── Pleno list ─────────────────────────────────────────────────────── */
  .plenos-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── Responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
  }
  @media (max-width: 768px) {
    .city-bar { height: auto; padding: 12px 16px 12px 20px; }
    .city-bar-meta { display: none; }
    .city-bar-cta  { display: none; }
    .city-bar-sep  { display: none; }
  }
</style>
