---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import PlenoCard from '../../components/PlenoCard.astro';
import {
  getMunicipio,
  getPlenosByMunicipio,
  supabase,
  CATEGORIAS,
} from '../../lib/supabase';

const { slug } = Astro.params;
const municipio = await getMunicipio(slug!);
if (!municipio) return Astro.redirect("/");

const page = Number(Astro.url.searchParams.get("page") ?? 1);
const { data: plenos, count } = await getPlenosByMunicipio(municipio.id, page);
const totalPages = Math.ceil((count ?? 0) / 20);

// ── Stats + highlights en una sola query ──────────────────────────────────
let totalAprobados = 0, totalRechazados = 0, totalPuntos = 0;
let catStats: { categoria: string; total: number }[] = [];
let highlightsByPleno: Record<string, { titulo: string; categoria: string; resultado: string }[]> = {};

try {
  const ids = plenos.map((p) => p.id);
  if (ids.length > 0) {
    const { data: pts } = await supabase
      .from("puntos")
      .select("pleno_id, titulo, categoria, resultado, relevancia_social, tipo")
      .in("pleno_id", ids);

    const allPts = pts ?? [];
    totalPuntos     = allPts.length;
    totalAprobados  = allPts.filter((p) => p.resultado === "aprobado").length;
    totalRechazados = allPts.filter((p) => p.resultado === "rechazado").length;

    // Categorías globales
    const counts: Record<string, number> = {};
    for (const row of allPts.filter((p) => p.categoria && p.categoria !== "otro")) {
      counts[row.categoria] = (counts[row.categoria] ?? 0) + 1;
    }
    catStats = Object.entries(counts)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 6)
      .map(([categoria, total]) => ({ categoria, total }));

    // Highlights por pleno: hasta 3 puntos más relevantes, excluyendo dar_cuenta
    for (const pt of allPts) {
      if (!pt.titulo || pt.tipo === "dar_cuenta") continue;
      if (!highlightsByPleno[pt.pleno_id]) highlightsByPleno[pt.pleno_id] = [];
      if (highlightsByPleno[pt.pleno_id].length < 3) {
        highlightsByPleno[pt.pleno_id].push({
          titulo:    pt.titulo,
          categoria: pt.categoria ?? "otro",
          resultado: pt.resultado ?? "sin_votacion",
        });
      }
    }
    // Reordenar: primero los de mayor relevancia_social
    const byRelevance: Record<string, typeof allPts> = {};
    for (const pt of allPts.filter(p => p.tipo !== "dar_cuenta" && p.titulo)) {
      if (!byRelevance[pt.pleno_id]) byRelevance[pt.pleno_id] = [];
      byRelevance[pt.pleno_id].push(pt);
    }
    highlightsByPleno = {};
    for (const [pid, pts2] of Object.entries(byRelevance)) {
      highlightsByPleno[pid] = pts2
        .sort((a, b) => (b.relevancia_social ?? 0) - (a.relevancia_social ?? 0))
        .slice(0, 3)
        .map(p => ({ titulo: p.titulo, categoria: p.categoria ?? "otro", resultado: p.resultado ?? "sin_votacion" }));
    }
  }
} catch {}

const ultimaFecha = plenos[0]?.fecha
  ? new Date(plenos[0].fecha + "T12:00:00").toLocaleDateString("es-ES", {
      day: "numeric", month: "long", year: "numeric",
    })
  : null;

const primerFecha = plenos.length > 0
  ? new Date(plenos[plenos.length - 1].fecha + "T12:00:00").toLocaleDateString("es-ES", {
      month: "long", year: "numeric",
    })
  : null;
---

<Base
  title={`${municipio.nombre} · Plenos Municipales · Acta Civium`}
  description={`Plenos municipales del Ayuntamiento de ${municipio.nombre}. ${count} actas analizadas desde una perspectiva ciudadana.`}
>

  <!-- ── MIGAS ─────────────────────────────────────────────────────────── -->
  <nav class="flex items-center gap-2 text-xs text-[var(--color-ink-muted)] mb-8">
    <a href="/" class="hover:underline">← Inicio</a>
    <span>/</span>
    <span class="text-[var(--color-ink)] font-medium">{municipio.nombre}</span>
  </nav>

  <!-- ── CABECERA DE CIUDAD ────────────────────────────────────────────── -->
  <header class="mb-10 pb-8 border-b-2 border-[var(--color-ink)]">
    <!-- Franja de color del gobierno -->
    <div class="h-1.5 w-12 mb-6 rounded-sm"
         style={`background: ${municipio.color_gobierno ?? '#1a3a2a'}`} />

    <div class="flex flex-wrap items-start justify-between gap-6">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-ink-muted)] mb-2">
          {municipio.provincia} · {municipio.comunidad}
        </p>
        <h1 class="headline-xl mb-1">
          {municipio.nombre}
          {municipio.nombre_alt && municipio.nombre_alt !== municipio.nombre && (
            <span class="font-normal text-[var(--color-ink-muted)]"> · {municipio.nombre_alt}</span>
          )}
        </h1>
        {ultimaFecha && (
          <p class="text-sm text-[var(--color-ink-muted)] mt-2">
            Cobertura desde {primerFecha} · Último pleno: {ultimaFecha}
          </p>
        )}
      </div>

      <a href="/newsletter"
         class="shrink-0 bg-[var(--color-accent)] text-white text-sm font-bold px-5 py-3 hover:bg-[#0f2218] transition-colors">
        Recibir newsletter →
      </a>
    </div>
  </header>

  <!-- ── DASHBOARD DE MÉTRICAS ─────────────────────────────────────────── -->
  <section class="mb-10">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 border border-[var(--color-border)] divide-x divide-y sm:divide-y-0 divide-[var(--color-border)]">
      {[
        { label: "Actas analizadas",   value: count,           sub: "" },
        { label: "Puntos tratados",    value: totalPuntos,     sub: "" },
        { label: "Aprobados",          value: totalAprobados,  sub: "", cls: "text-[#1b5e20]" },
        { label: "Rechazados",         value: totalRechazados, sub: "", cls: "text-[#c41a1a]" },
        { label: "Concejales",         value: municipio.n_concejales ?? "—", sub: "" },
        { label: "Gobierno",           value: municipio.partido_gobierno ?? "—",
          sub: municipio.alcalde ? municipio.alcalde.split(" ").slice(-2).join(" ") : "",
          cls: "text-base leading-tight" },
      ].map(({ label, value, sub, cls }) => (
        <div class="text-center py-5 px-2 bg-white">
          <p class:list={["font-serif font-bold", cls ?? "text-3xl"]}>{value}</p>
          {sub && <p class="text-[10px] text-[var(--color-ink-muted)] mt-0.5">{sub}</p>}
          <p class="text-[10px] uppercase tracking-widest text-[var(--color-ink-muted)] mt-1">{label}</p>
        </div>
      ))}
    </div>
  </section>

  <div class="grid lg:grid-cols-[1fr_260px] gap-10">

    <!-- ── LISTA DE ACTAS ───────────────────────────────────────────────── -->
    <div>
      <div class="section-rule mb-6">
        <span class="text-xs font-bold uppercase tracking-widest">
          Actas de plenos · {count} {(count ?? 0) === 1 ? "sesión" : "sesiones"}
        </span>
      </div>

      {plenos.length === 0 ? (
        <p class="text-[var(--color-ink-muted)] text-sm py-8 text-center border border-dashed border-[var(--color-border)]">
          No hay actas procesadas todavía.
        </p>
      ) : (
        <>
          <div>
            {plenos.map((p, i) => <PlenoCard pleno={p} featured={i === 0 && page === 1} highlights={highlightsByPleno[p.id]} />)}
          </div>

          {totalPages > 1 && (
            <nav class="flex justify-between items-center mt-8 pt-4 border-t border-[var(--color-border)]">
              {page > 1
                ? <a href={`/ciudad/${slug}?page=${page - 1}`} class="text-sm font-semibold hover:underline">← Más recientes</a>
                : <span />}
              <span class="text-xs text-[var(--color-ink-muted)]">Página {page} de {totalPages}</span>
              {page < totalPages
                ? <a href={`/ciudad/${slug}?page=${page + 1}`} class="text-sm font-semibold hover:underline">Anteriores →</a>
                : <span />}
            </nav>
          )}
        </>
      )}
    </div>

    <!-- ── SIDEBAR ──────────────────────────────────────────────────────── -->
    <aside class="space-y-8">

      <!-- Ficha del municipio -->
      <div class="border border-[var(--color-border)] p-4 text-sm space-y-3">
        <div class="section-rule">
          <span class="text-xs font-bold uppercase tracking-widest">Ficha</span>
        </div>
        <dl class="space-y-2.5">
          {municipio.alcalde && (
            <div>
              <dt class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)]">Alcalde/sa</dt>
              <dd class="font-medium mt-0.5">{municipio.alcalde}</dd>
            </div>
          )}
          {municipio.partido_gobierno && (
            <div>
              <dt class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)]">Partido de gobierno</dt>
              <dd class="font-medium mt-0.5 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full inline-block"
                      style={`background: ${municipio.color_gobierno ?? '#888'}`} />
                {municipio.partido_gobierno}
              </dd>
            </div>
          )}
          {municipio.n_concejales && (
            <div>
              <dt class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)]">Concejales</dt>
              <dd class="font-medium mt-0.5">{municipio.n_concejales}</dd>
            </div>
          )}
          {municipio.poblacion && (
            <div>
              <dt class="text-[10px] uppercase tracking-wider text-[var(--color-ink-muted)]">Población</dt>
              <dd class="font-medium mt-0.5">{municipio.poblacion.toLocaleString("es-ES")} hab.</dd>
            </div>
          )}
          {municipio.web_oficial && (
            <div class="pt-1">
              <a href={municipio.web_oficial} target="_blank" rel="noopener noreferrer"
                 class="text-xs font-semibold text-[var(--color-accent)] hover:underline">
                Web oficial del Ayuntamiento →
              </a>
            </div>
          )}
        </dl>
      </div>

      <!-- Temas más tratados -->
      {catStats.length > 0 && (
        <div>
          <div class="section-rule mb-4">
            <span class="text-xs font-bold uppercase tracking-widest">Temas más tratados</span>
          </div>
          <div class="space-y-2">
            {catStats.map(({ categoria, total }) => (
              <a
                href={`/temas/${categoria}`}
                class="flex items-center justify-between py-1.5 border-b border-[var(--color-border)] last:border-0 hover:text-[var(--color-accent)] transition-colors group"
              >
                <span class:list={["badge", `badge-${categoria}`]}>
                  {CATEGORIAS[categoria] ?? categoria}
                </span>
                <span class="text-xs text-[var(--color-ink-muted)] group-hover:text-[var(--color-accent)]">
                  {total} {total === 1 ? "punto" : "puntos"}
                </span>
              </a>
            ))}
          </div>
        </div>
      )}

    </aside>
  </div>

</Base>
