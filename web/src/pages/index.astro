---
export const prerender = false;
import Base from '../layouts/Base.astro';
import { getMunicipios, getPuntosRelevantes, supabase } from '../lib/supabase';

const municipios = await getMunicipios();

let totalActas = 0, totalPuntos = 0;
try {
  const [a, p] = await Promise.all([
    supabase.from("plenos").select("*", { count: "exact", head: true }).eq("estado", "procesado"),
    supabase.from("puntos").select("*", { count: "exact", head: true }),
  ]);
  totalActas  = a.count ?? 0;
  totalPuntos = p.count ?? 0;
} catch {}

const puntosDestacados = await getPuntosRelevantes(3);

const CATEGORIAS: Record<string, string> = {
  urbanismo: "Urbanismo", vivienda: "Vivienda", hacienda: "Hacienda",
  medio_ambiente: "Medio Ambiente", servicios_sociales: "Serv. Sociales",
  movilidad: "Movilidad", cultura: "Cultura", gobernanza: "Gobernanza",
  derechos: "Derechos", seguridad: "Seguridad", educacion: "Educación", otro: "Otro",
};
---

<Base
  title="Acta Civium"
  description="Los plenos municipales en lenguaje ciudadano. Analizamos las actas del Ayuntamiento y te enviamos lo que importa cada semana."
>

  <!-- ── HERO ────────────────────────────────────────────────────────────── -->
  <section class="hero-section -mx-8 -mt-8">
    <div class="hero-inner">
      <div class="hero-eyebrow">
        <span class="hero-dot" />
        Transparencia Municipal · España
      </div>

      <h1 class="hero-h1">
        El pleno municipal,<br />
        <em>en lenguaje ciudadano.</em>
      </h1>

      <p class="hero-subtitle">
        Analizamos las actas del Ayuntamiento y te enviamos
        lo que importa. Semanal y gratuito.
      </p>

      <form action="/newsletter" method="GET" class="hero-form">
        <input type="email" name="email" placeholder="tu@email.com" required class="hero-input" />
        <button type="submit" class="hero-btn">Suscribirme gratis →</button>
      </form>
      <p class="hero-disclaimer">Sin spam · Un correo semanal · Cancelar cuando quieras</p>
    </div>
  </section>

  <!-- ── STATS BAR ──────────────────────────────────────────────────────── -->
  <div class="stats-bar -mx-8">
    {[
      { value: totalActas,        label: "Actas analizadas" },
      { value: totalPuntos,       label: "Puntos debatidos" },
      { value: municipios.length, label: "Municipios cubiertos" },
      { value: "Semanal",         label: "Frecuencia de actualización" },
    ].map(({ value, label }) => (
      <div class="stats-cell">
        <p class="stats-value">{value}</p>
        <p class="stats-label">{label}</p>
      </div>
    ))}
  </div>

  <!-- ── MUNICIPIOS ─────────────────────────────────────────────────────── -->
  <section class="content-section">
    <div class="section-header">
      <span class="section-label-text">Municipios cubiertos</span>
      <div class="section-line" />
    </div>

    <div class="muni-grid">
      {municipios.map((m) => (
        <a href={`/ciudad/${m.slug}`} class="muni-card">
          <div class="muni-stripe" style={`background: ${m.color_gobierno ?? 'var(--color-accent)'}`} />
          <p class="muni-name">
            {m.nombre}
            {m.nombre_alt && m.nombre_alt !== m.nombre && (
              <span class="muni-alt"> · {m.nombre_alt}</span>
            )}
          </p>
          <p class="muni-location">{m.provincia} · {m.comunidad}</p>
          <div class="muni-footer">
            <span class="muni-gov">
              {m.partido_gobierno ? <span>Gobierno: <strong>{m.partido_gobierno}</strong></span> : "Plenos analizados"}
            </span>
            <span class="muni-cta">Ver plenos →</span>
          </div>
        </a>
      ))}

      <div class="muni-card muni-card--soon">
        <p class="muni-soon-plus">+</p>
        <p class="muni-soon-title">Más municipios</p>
        <p class="muni-soon-sub">Próximamente</p>
      </div>
    </div>
  </section>

  <!-- ── HIGHLIGHTS ─────────────────────────────────────────────────────── -->
  {puntosDestacados.length > 0 && (
    <section class="content-section">
      <div class="section-header">
        <span class="section-label-text">Decisiones recientes destacadas</span>
        <div class="section-line" />
      </div>

      <div class="highlights-grid">
        {puntosDestacados.map((p: any) => {
          const fecha = p.fecha_pleno
            ? new Date(p.fecha_pleno + "T12:00:00").toLocaleDateString("es-ES", { day: "numeric", month: "short", year: "numeric" })
            : p.municipio ?? "";
          const aprobado = p.resultado === "aprobado";
          const rechazado = p.resultado === "rechazado";
          const cat = p.categoria && p.categoria !== "otro" ? p.categoria : null;
          return (
            <a href={`/acta/${p.pleno_id ?? ""}`} class="highlight-card">
              <div class="highlight-top">
                {cat && <span class:list={["badge", `badge-${cat}`]}>{CATEGORIAS[cat]}</span>}
                <span class="highlight-date">{fecha}</span>
              </div>
              <p class="highlight-title">{p.titulo}</p>
              {p.resumen_ia && <p class="highlight-desc">{p.resumen_ia.slice(0, 160)}{p.resumen_ia.length > 160 ? "…" : ""}</p>}
              <div class="highlight-footer">
                {aprobado  && <span class="highlight-resultado highlight-resultado--ok">✓ Aprobado</span>}
                {rechazado && <span class="highlight-resultado highlight-resultado--no">✗ Rechazado</span>}
                {!aprobado && !rechazado && <span class="highlight-resultado">Enterado</span>}
                <span class="highlight-leer">Leer más →</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- ── CÓMO FUNCIONA ─────────────────────────────────────────────────── -->
  <section class="content-section">
    <div class="section-header">
      <span class="section-label-text">Cómo funciona</span>
      <div class="section-line" />
    </div>
    <div class="how-grid">
      {[
        { num: "01", title: "Descargamos el acta",
          desc: "Monitorizamos el portal de cada Ayuntamiento y descargamos automáticamente cada acta publicada." },
        { num: "02", title: "Analizamos el contenido",
          desc: "Extraemos los puntos del orden del día, los clasificamos por tema y detectamos quién votó qué." },
        { num: "03", title: "Te lo enviamos",
          desc: "Recibes un resumen semanal con las decisiones que afectan a tu ciudad, claro y sin tecnicismos." },
      ].map(({ num, title, desc }) => (
        <div class="how-step">
          <p class="how-num">{num}</p>
          <h3 class="how-title">{title}</h3>
          <p class="how-desc">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── SEGUNDO CTA ───────────────────────────────────────────────────── -->
  <section class="cta2-section -mx-8">
    <div class="cta2-inner">
      <h2 class="cta2-h2">No te pierdas ningún pleno</h2>
      <p class="cta2-sub">
        Suscríbete a la newsletter y recibe cada semana el análisis de los
        acuerdos municipales de tu ciudad.
      </p>
      <form action="/newsletter" method="GET" class="cta2-form">
        <input type="email" name="email" placeholder="tu@email.com" required class="cta2-input" />
        <button type="submit" class="cta2-btn">Suscribirme</button>
      </form>
    </div>
  </section>

</Base>

<style>
  /* Hero */
  .hero-section {
    padding: 96px 32px 80px;
    text-align: center;
    background:
      radial-gradient(ellipse 70% 55% at 50% -10%, oklch(92% 0.04 158 / 0.35) 0%, transparent 70%),
      radial-gradient(ellipse 50% 30% at 80% 110%, oklch(94% 0.025 195 / 0.25) 0%, transparent 65%);
  }
  .hero-inner { max-width: 760px; margin: 0 auto; }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 20px;
  }
  .hero-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
  }
  .hero-h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin-bottom: 20px;
  }
  .hero-h1 em {
    font-style: italic;
    color: var(--color-accent);
  }
  .hero-subtitle {
    font-size: clamp(1rem, 1.6vw, 1.125rem);
    line-height: 1.7;
    color: var(--color-ink-muted);
    max-width: 520px;
    margin: 0 auto 32px;
  }
  .hero-form {
    display: flex;
    gap: 8px;
    max-width: 440px;
    margin: 0 auto 12px;
  }
  .hero-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink);
    background: white;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .hero-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px oklch(42% 0.13 158 / 0.1);
  }
  .hero-btn {
    padding: 12px 22px;
    background: var(--color-accent);
    color: white;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s, transform 0.15s;
  }
  .hero-btn:hover { background: oklch(36% 0.13 158); transform: translateY(-1px); }
  .hero-btn:active { transform: translateY(0); }
  .hero-disclaimer { font-size: 0.75rem; color: var(--color-ink-subtle); }

  /* Stats bar */
  .stats-bar {
    display: flex;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-card);
    margin-bottom: 64px;
  }
  .stats-cell {
    flex: 1;
    padding: 20px 16px;
    text-align: center;
    border-right: 1px solid var(--color-border);
  }
  .stats-cell:last-child { border-right: none; }
  .stats-value {
    font-family: var(--font-serif);
    font-size: 1.875rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }
  .stats-label {
    font-size: 0.75rem;
    color: var(--color-ink-subtle);
    letter-spacing: 0.02em;
    margin-top: 4px;
  }

  /* Content sections */
  .content-section { padding: 0 0 72px; }
  .section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }
  .section-label-text {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
    white-space: nowrap;
  }
  .section-line {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  /* Municipality cards */
  .muni-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }
  .muni-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 22px 22px 18px;
    text-decoration: none;
    color: var(--color-ink);
    display: block;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }
  .muni-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
  }
  .muni-stripe {
    height: 3px;
    width: 32px;
    border-radius: 99px;
    margin-bottom: 14px;
  }
  .muni-name {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .muni-alt { font-size: 0.875rem; font-weight: 400; color: var(--color-ink-muted); }
  .muni-location { font-size: 0.75rem; color: var(--color-ink-subtle); margin-bottom: 14px; }
  .muni-footer {
    border-top: 1px solid var(--color-border);
    padding-top: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
  }
  .muni-gov { color: var(--color-ink-muted); }
  .muni-cta { font-weight: 600; color: var(--color-accent); }
  .muni-card--soon {
    border: 1px dashed var(--color-border);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    opacity: 0.55;
    cursor: default;
  }
  .muni-card--soon:hover { transform: none; box-shadow: none; border-color: var(--color-border); }
  .muni-soon-plus { font-size: 1.5rem; color: var(--color-ink-subtle); margin-bottom: 6px; }
  .muni-soon-title { font-size: 0.875rem; font-weight: 600; color: var(--color-ink); }
  .muni-soon-sub { font-size: 0.75rem; color: var(--color-ink-muted); margin-top: 4px; }

  /* Highlights */
  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .highlight-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 22px;
    text-decoration: none;
    color: var(--color-ink);
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }
  .highlight-card:hover { box-shadow: var(--shadow-md); border-color: var(--color-border-strong); transform: translateY(-2px); }
  .highlight-top { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
  .highlight-date { font-size: 0.6875rem; color: var(--color-ink-subtle); margin-left: auto; white-space: nowrap; }
  .highlight-title { font-family: var(--font-serif); font-size: 1rem; font-weight: 600; line-height: 1.35; margin-bottom: 8px; flex: 1; }
  .highlight-desc { font-size: 0.8125rem; color: var(--color-ink-muted); line-height: 1.6; margin-bottom: 12px; }
  .highlight-footer {
    border-top: 1px solid var(--color-border);
    padding-top: 12px;
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .highlight-resultado { font-size: 0.75rem; font-weight: 600; color: var(--color-ink-subtle); }
  .highlight-resultado--ok { color: var(--color-green); }
  .highlight-resultado--no { color: var(--color-red); }
  .highlight-leer { font-size: 0.75rem; font-weight: 600; color: var(--color-accent); }

  /* How it works */
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    max-width: 860px;
  }
  .how-step {}
  .how-num {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-mid) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 10px;
    line-height: 1;
  }
  .how-title { font-size: 1rem; font-weight: 600; color: var(--color-ink); margin-bottom: 8px; }
  .how-desc { font-size: 0.875rem; color: var(--color-ink-muted); line-height: 1.65; }

  /* Second CTA */
  .cta2-section {
    background: var(--color-accent-xlight);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 72px 32px;
  }
  .cta2-inner { max-width: 520px; margin: 0 auto; text-align: center; }
  .cta2-h2 { font-family: var(--font-serif); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; letter-spacing: -0.02em; color: var(--color-ink); margin-bottom: 12px; }
  .cta2-sub { font-size: 0.9375rem; color: var(--color-ink-muted); line-height: 1.65; margin-bottom: 24px; }
  .cta2-form { display: flex; gap: 8px; max-width: 420px; margin: 0 auto; }
  .cta2-input {
    flex: 1;
    padding: 11px 15px;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink);
    background: white;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .cta2-input:focus { border-color: var(--color-accent); box-shadow: 0 0 0 3px oklch(42% 0.13 158 / 0.1); }
  .cta2-btn {
    padding: 11px 20px;
    background: var(--color-accent);
    color: white;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s, transform 0.15s;
  }
  .cta2-btn:hover { background: oklch(36% 0.13 158); transform: translateY(-1px); }
  .cta2-btn:active { transform: translateY(0); }

  /* Responsive */
  @media (max-width: 900px) {
    .highlights-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .hero-section { padding: 56px 16px 48px; }
    .hero-form { flex-direction: column; }
    .stats-bar { display: grid; grid-template-columns: 1fr 1fr; }
    .stats-cell { border-right: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
    .stats-cell:nth-child(even) { border-right: none; }
    .stats-cell:nth-last-child(-n+2) { border-bottom: none; }
    .highlights-grid { grid-template-columns: 1fr; }
    .how-grid { grid-template-columns: 1fr; gap: 32px; }
    .cta2-section { padding: 48px 16px; }
    .cta2-form { flex-direction: column; }
  }
  @media (max-width: 480px) {
    .stats-value { font-size: 1.5rem; }
  }
</style>
