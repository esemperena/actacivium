---
import Base from '../layouts/Base.astro';
import PlenoCard from '../components/PlenoCard.astro';
import { getPlenos, getPuntosRelevantes, CATEGORIAS } from '../lib/supabase';

const plenos = await getPlenos(12);
const puntosRelevantes = await getPuntosRelevantes(8);

const ultimoPleno = plenos[0] ?? null;
const plenosRecientes = plenos.slice(1, 7);
---

<Base
  title="Acta Civium"
  description="Los plenos municipales de San Sebastián, en lenguaje ciudadano. Transparencia, impacto social y rendición de cuentas."
>
  <div class="grid md:grid-cols-[1fr_320px] gap-8">

    <!-- Columna principal -->
    <div>
      {ultimoPleno && (
        <section class="mb-8">
          <div class="section-rule mb-5">
            <span class="text-xs font-bold uppercase tracking-widest">Último pleno</span>
          </div>
          <PlenoCard pleno={ultimoPleno} featured />
        </section>
      )}

      <div class="section-rule mb-5">
        <span class="text-xs font-bold uppercase tracking-widest">Plenos anteriores</span>
      </div>

      <section class="grid md:grid-cols-2 gap-x-8">
        {plenosRecientes.map((p) => <PlenoCard pleno={p} />)}
      </section>

      <div class="mt-6 text-center">
        <a
          href="/actas"
          class="inline-block border border-[var(--color-ink)] text-sm font-semibold px-6 py-2 hover:bg-[var(--color-ink)] hover:text-[var(--color-bg)] transition-colors"
        >
          Ver todos los plenos →
        </a>
      </div>
    </div>

    <!-- Sidebar -->
    <aside class="border-l border-[var(--color-border)] pl-6 space-y-8">

      <!-- Newsletter -->
      <div class="bg-[var(--color-accent)] text-white p-5">
        <p class="font-serif font-bold text-lg mb-1">Newsletter semanal</p>
        <p class="text-sm text-green-200 mb-4 leading-relaxed">
          Los acuerdos que importan, cada semana en tu bandeja de entrada.
        </p>
        <form action="/newsletter" method="GET">
          <input
            type="email"
            name="email"
            placeholder="tu@email.com"
            class="w-full px-3 py-2 text-sm text-[var(--color-ink)] mb-2 border-0 focus:ring-2 focus:ring-white outline-none"
          />
          <button
            type="submit"
            class="w-full bg-white text-[var(--color-accent)] font-bold text-sm py-2 hover:bg-green-50 transition-colors"
          >
            Suscribirse
          </button>
        </form>
      </div>

      <!-- Decisiones de alto impacto -->
      {puntosRelevantes.length > 0 && (
        <div>
          <div class="section-rule mb-4">
            <span class="text-xs font-bold uppercase tracking-widest">Decisiones destacadas</span>
          </div>
          <ul class="space-y-4">
            {puntosRelevantes.map((p) => (
              <li class="border-b border-[var(--color-border)] pb-4 last:border-0">
                <span class:list={["badge mb-1", `badge-${p.categoria}`]}>
                  {CATEGORIAS[p.categoria] ?? p.categoria}
                </span>
                <a href={`/acta/${p.pleno_id}`} class="block font-serif text-sm font-medium leading-snug hover:underline mt-1">
                  {p.titulo}
                </a>
                <p class="text-xs text-[var(--color-ink-muted)] mt-1">
                  {new Date(p.fecha).toLocaleDateString("es-ES", { day: "numeric", month: "short", year: "numeric" })}
                  {" · "}
                  <span class:list={[
                    p.resultado === "aprobado" && "resultado-aprobado",
                    p.resultado === "rechazado" && "resultado-rechazado",
                  ]}>
                    {p.resultado === "aprobado" ? "Aprobado" : p.resultado === "rechazado" ? "Rechazado" : ""}
                  </span>
                </p>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Temas -->
      <div>
        <div class="section-rule mb-4">
          <span class="text-xs font-bold uppercase tracking-widest">Por tema</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {Object.entries(CATEGORIAS).filter(([k]) => k !== "otro").map(([slug, label]) => (
            <a
              href={`/temas/${slug}`}
              class:list={["badge hover:opacity-80 transition-opacity cursor-pointer", `badge-${slug}`]}
            >
              {label}
            </a>
          ))}
        </div>
      </div>

    </aside>
  </div>
</Base>
