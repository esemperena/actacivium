---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Acta Civium analiza los plenos municipales de San Sebastián con una mirada ciudadana, social y medioambiental.",
  ogImage = "/og-default.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://actacivium.netlify.app");
const fullTitle = title === "Acta Civium" ? title : `${title} — Acta Civium`;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Acta Civium",
      "description": description,
      "url": Astro.site,
      "inLanguage": "es",
    })} />

    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>

  <body class="min-h-screen flex flex-col">

    <!-- ── Franja utilitaria superior ────────────────────────────────────── -->
    <div style="border-bottom: 1px solid var(--color-border); padding: 5px 32px; display: flex; justify-content: space-between; align-items: center;">
      <span style="font-size: 0.6875rem; color: var(--color-ink-subtle); letter-spacing: 0.05em;">
        San Sebastián · Plenos Municipales
      </span>
      <a
        href="/newsletter"
        style="font-size: 0.6875rem; font-weight: 600; color: var(--color-accent-mid);"
      >
        Suscríbete a la newsletter →
      </a>
    </div>

    <!-- ── Cabecera principal ─────────────────────────────────────────────── -->
    <header style="background: var(--color-bg-card); border-bottom: 1px solid var(--color-border); position: sticky; top: 0; z-index: 100;">
      <div style="max-width: 1200px; margin: 0 auto; padding: 14px 32px; display: flex; align-items: center; justify-content: space-between;">

        <!-- Logo + wordmark -->
        <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--color-ink);">
          <svg width="26" height="26" viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink: 0;">
            <path fill="var(--color-accent)" d="M50.4 78.5a75.1 75.1 0 0 0-28.5 6.9l24.2-65.7c.7-2 1.9-3.2 3.4-3.2h29c1.5 0 2.7 1.2 3.4 3.2l24.2 65.7s-11.6-7-28.5-7L67 45.5c-.4-1.7-1.6-2.8-2.9-2.8-1.3 0-2.5 1.1-2.9 2.7L50.4 78.5Zm-1.1 28.2Zm-4.2-20.2c-2 6.6-.6 15.8 4.2 20.2a17.5 17.5 0 0 1 .2-.7 5.5 5.5 0 0 1 5.7-4.5c2.8.1 4.3 1.5 4.7 4.7.2 1.1.2 2.3.2 3.5v.4c0 2.7.7 5.2 2.2 7.4a13 13 0 0 0 5.7 4.9v-.3l-.2-.3c-1.8-5.6-.5-9.5 4.4-12.8l1.5-1a73 73 0 0 0 3.2-2.2 16 16 0 0 0 6.8-11.4c.3-2 .1-4-.6-6l-.8.6-1.6 1a37 37 0 0 1-22.4 2.7c-5-.7-9.7-2-13.2-6.2Z"/>
          </svg>
          <span style="font-family: var(--font-serif); font-weight: 700; font-size: 1.25rem; letter-spacing: -0.025em;">
            Acta Civium
          </span>
        </a>

        <!-- Navegación -->
        <nav style="display: flex; gap: 4px;">
          {[
            { href: "/",          label: "Inicio"      },
            { href: "/actas",     label: "Actas"       },
            { href: "/temas",     label: "Por tema"    },
            { href: "/newsletter",label: "Newsletter"  },
            { href: "/sobre",     label: "Sobre el proyecto" },
          ].map(({ href, label }) => {
            const active = currentPath === href || (href !== "/" && currentPath.startsWith(href));
            return (
              <a
                href={href}
                style={`
                  padding: 6px 14px;
                  border-radius: var(--radius);
                  font-size: 0.875rem;
                  font-weight: ${active ? "600" : "400"};
                  text-decoration: none;
                  background: ${active ? "var(--color-accent-light)" : "transparent"};
                  color: ${active ? "var(--color-accent)" : "var(--color-ink-muted)"};
                  transition: background 0.15s, color 0.15s;
                `}
              >
                {label}
              </a>
            );
          })}
        </nav>
      </div>
    </header>

    <main class="flex-1 max-w-[1200px] mx-auto w-full px-8 py-8">
      <slot />
    </main>

    <!-- ── Footer ─────────────────────────────────────────────────────────── -->
    <footer style="background: var(--color-ink); color: oklch(72% 0.01 255); padding: 48px 32px 32px; margin-top: auto;">
      <div style="max-width: 1200px; margin: 0 auto;">
        <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 40px; margin-bottom: 40px;">

          <!-- Brand -->
          <div>
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px;">
              <svg width="22" height="22" viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path fill="white" d="M50.4 78.5a75.1 75.1 0 0 0-28.5 6.9l24.2-65.7c.7-2 1.9-3.2 3.4-3.2h29c1.5 0 2.7 1.2 3.4 3.2l24.2 65.7s-11.6-7-28.5-7L67 45.5c-.4-1.7-1.6-2.8-2.9-2.8-1.3 0-2.5 1.1-2.9 2.7L50.4 78.5Zm-1.1 28.2Zm-4.2-20.2c-2 6.6-.6 15.8 4.2 20.2a17.5 17.5 0 0 1 .2-.7 5.5 5.5 0 0 1 5.7-4.5c2.8.1 4.3 1.5 4.7 4.7.2 1.1.2 2.3.2 3.5v.4c0 2.7.7 5.2 2.2 7.4a13 13 0 0 0 5.7 4.9v-.3l-.2-.3c-1.8-5.6-.5-9.5 4.4-12.8l1.5-1a73 73 0 0 0 3.2-2.2 16 16 0 0 0 6.8-11.4c.3-2 .1-4-.6-6l-.8.6-1.6 1a37 37 0 0 1-22.4 2.7c-5-.7-9.7-2-13.2-6.2Z"/>
              </svg>
              <span style="font-family: var(--font-serif); font-weight: 700; font-size: 1.1rem; color: white; letter-spacing: -0.02em;">
                Acta Civium
              </span>
            </div>
            <p style="font-size: 0.875rem; line-height: 1.65; color: oklch(60% 0.01 255); max-width: 320px;">
              Transparencia municipal desde una perspectiva ciudadana, social y medioambiental. Código abierto.
            </p>
          </div>

          <!-- Navegación -->
          <div>
            <p style="font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: oklch(50% 0.008 255); margin-bottom: 12px;">
              Navegación
            </p>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 6px;">
              {[
                ["/actas", "Actas de plenos"],
                ["/temas", "Por tema"],
                ["/newsletter", "Newsletter"],
                ["/sobre", "Sobre el proyecto"],
              ].map(([href, label]) => (
                <li>
                  <a href={href} style="font-size: 0.875rem; color: oklch(65% 0.01 255); text-decoration: none; transition: color 0.15s;"
                     onmouseover="this.style.color='white'" onmouseout="this.style.color='oklch(65% 0.01 255)'">
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Municipios -->
          <div>
            <p style="font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: oklch(50% 0.008 255); margin-bottom: 12px;">
              Municipios
            </p>
            <p style="font-size: 0.875rem; color: white; margin-bottom: 4px;">San Sebastián · Donostia</p>
            <p style="font-size: 0.8125rem; color: oklch(45% 0.008 255); font-style: italic;">Más municipios próximamente</p>
            <p style="margin-top: 16px; font-size: 0.75rem; color: oklch(40% 0.008 255);">
              Fuente: <a href="https://www.donostia.eus" target="_blank" rel="noopener" style="text-decoration: underline; color: inherit;">donostia.eus</a>
            </p>
          </div>
        </div>

        <div style="padding-top: 20px; border-top: 1px solid oklch(28% 0.01 255); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
          <span style="font-size: 0.75rem; color: oklch(45% 0.008 255);">
            © {new Date().getFullYear()} Acta Civium · Proyecto de código abierto · MIT License
          </span>
          <span style="font-size: 0.75rem; color: oklch(45% 0.008 255);">
            Datos: Ayuntamiento de San Sebastián · CC BY 4.0
          </span>
        </div>
      </div>
    </footer>

  </body>
</html>
