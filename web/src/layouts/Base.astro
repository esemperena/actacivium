---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Acta Civium analiza los plenos municipales de San Sebastián con una mirada ciudadana, social y medioambiental.",
  ogImage = "/og-default.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://actacivium.netlify.app");
const fullTitle = title === "Acta Civium" ? title : `${title} — Acta Civium`;
const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Acta Civium",
      "description": description,
      "url": Astro.site,
      "inLanguage": "es",
    })} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>

  <body class="min-h-screen flex flex-col">

    {isHome && (
      <div class="utility-bar">
        <span class="utility-location">San Sebastián · Plenos Municipales</span>
        <a href="/newsletter" class="utility-link">Suscríbete a la newsletter →</a>
      </div>
    )}

    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="logo-link">
          <svg width="26" height="26" viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0">
            <path fill="var(--color-accent)" d="M50.4 78.5a75.1 75.1 0 0 0-28.5 6.9l24.2-65.7c.7-2 1.9-3.2 3.4-3.2h29c1.5 0 2.7 1.2 3.4 3.2l24.2 65.7s-11.6-7-28.5-7L67 45.5c-.4-1.7-1.6-2.8-2.9-2.8-1.3 0-2.5 1.1-2.9 2.7L50.4 78.5Zm-1.1 28.2Zm-4.2-20.2c-2 6.6-.6 15.8 4.2 20.2a17.5 17.5 0 0 1 .2-.7 5.5 5.5 0 0 1 5.7-4.5c2.8.1 4.3 1.5 4.7 4.7.2 1.1.2 2.3.2 3.5v.4c0 2.7.7 5.2 2.2 7.4a13 13 0 0 0 5.7 4.9v-.3l-.2-.3c-1.8-5.6-.5-9.5 4.4-12.8l1.5-1a73 73 0 0 0 3.2-2.2 16 16 0 0 0 6.8-11.4c.3-2 .1-4-.6-6l-.8.6-1.6 1a37 37 0 0 1-22.4 2.7c-5-.7-9.7-2-13.2-6.2Z"/>
          </svg>
          <span class="logo-wordmark">Acta Civium</span>
        </a>

        <nav class="main-nav">
          {[
            { href: "/",           label: "Inicio"     },
            { href: "/actas",      label: "Actas"      },
            { href: "/temas",      label: "Por tema"   },
            { href: "/newsletter", label: "Newsletter" },
            { href: "/sobre",      label: "Sobre"      },
          ].map(({ href, label }) => {
            const active = currentPath === href || (href !== "/" && currentPath.startsWith(href));
            return (
              <a href={href} class:list={["nav-link", active && "nav-link--active"]}>{label}</a>
            );
          })}
        </nav>
      </div>
    </header>

    <main class="flex-1 max-w-[1200px] mx-auto w-full px-8 py-8">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-grid">
          <div>
            <div class="footer-logo">
              <svg width="22" height="22" viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path fill="white" d="M50.4 78.5a75.1 75.1 0 0 0-28.5 6.9l24.2-65.7c.7-2 1.9-3.2 3.4-3.2h29c1.5 0 2.7 1.2 3.4 3.2l24.2 65.7s-11.6-7-28.5-7L67 45.5c-.4-1.7-1.6-2.8-2.9-2.8-1.3 0-2.5 1.1-2.9 2.7L50.4 78.5Zm-1.1 28.2Zm-4.2-20.2c-2 6.6-.6 15.8 4.2 20.2a17.5 17.5 0 0 1 .2-.7 5.5 5.5 0 0 1 5.7-4.5c2.8.1 4.3 1.5 4.7 4.7.2 1.1.2 2.3.2 3.5v.4c0 2.7.7 5.2 2.2 7.4a13 13 0 0 0 5.7 4.9v-.3l-.2-.3c-1.8-5.6-.5-9.5 4.4-12.8l1.5-1a73 73 0 0 0 3.2-2.2 16 16 0 0 0 6.8-11.4c.3-2 .1-4-.6-6l-.8.6-1.6 1a37 37 0 0 1-22.4 2.7c-5-.7-9.7-2-13.2-6.2Z"/>
              </svg>
              <span class="footer-wordmark">Acta Civium</span>
            </div>
            <p class="footer-desc">Transparencia municipal desde una perspectiva ciudadana, social y medioambiental. Código abierto.</p>
          </div>

          <div>
            <p class="footer-col-label">Navegación</p>
            <ul class="footer-links">
              {[["/actas","Actas de plenos"],["/temas","Por tema"],["/newsletter","Newsletter"],["/sobre","Sobre el proyecto"]].map(([href, label]) => (
                <li><a href={href} class="footer-link">{label}</a></li>
              ))}
            </ul>
          </div>

          <div>
            <p class="footer-col-label">Municipios</p>
            <p class="footer-muni-name">San Sebastián · Donostia</p>
            <p class="footer-muni-more">Más municipios próximamente</p>
            <p class="footer-source">Fuente: <a href="https://www.donostia.eus" target="_blank" rel="noopener" class="footer-source-link">donostia.eus</a></p>
          </div>
        </div>

        <div class="footer-bottom">
          <span>© {new Date().getFullYear()} Acta Civium · Proyecto de código abierto · MIT License</span>
          <span>Datos: Ayuntamiento de San Sebastián · CC BY 4.0</span>
        </div>
      </div>
    </footer>

  </body>
</html>

<style>
  .utility-bar { border-bottom: 1px solid var(--color-border); padding: 5px 32px; display: flex; justify-content: space-between; align-items: center; }
  .utility-location { font-size: 0.6875rem; color: var(--color-ink-subtle); letter-spacing: 0.05em; }
  .utility-link { font-size: 0.6875rem; font-weight: 600; color: var(--color-accent-mid); text-decoration: none; transition: color 0.15s; }
  .utility-link:hover { color: var(--color-accent); }

  .site-header { background: var(--color-bg-card); border-bottom: 1px solid var(--color-border); position: sticky; top: 0; z-index: 100; }
  .header-inner { max-width: 1200px; margin: 0 auto; padding: 14px 32px; display: flex; align-items: center; justify-content: space-between; }
  .logo-link { display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--color-ink); }
  .logo-wordmark { font-family: var(--font-serif); font-weight: 700; font-size: 1.25rem; letter-spacing: -0.025em; }
  .main-nav { display: flex; gap: 4px; }
  .nav-link { padding: 6px 14px; border-radius: var(--radius); font-size: 0.875rem; font-weight: 400; text-decoration: none; color: var(--color-ink-muted); background: transparent; transition: background 0.15s, color 0.15s; }
  .nav-link:hover { background: var(--color-accent-xlight); color: var(--color-accent); }
  .nav-link--active { background: var(--color-accent-light); color: var(--color-accent); font-weight: 600; }

  .site-footer { background: var(--color-ink); color: oklch(72% 0.01 255); padding: 56px 32px 32px; margin-top: auto; }
  .footer-inner { max-width: 1200px; margin: 0 auto; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 40px; margin-bottom: 40px; }
  .footer-logo { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
  .footer-wordmark { font-family: var(--font-serif); font-weight: 700; font-size: 1.1rem; color: white; letter-spacing: -0.02em; }
  .footer-desc { font-size: 0.875rem; line-height: 1.65; color: oklch(60% 0.01 255); max-width: 320px; }
  .footer-col-label { font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: oklch(50% 0.008 255); margin-bottom: 12px; }
  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .footer-link { font-size: 0.875rem; color: oklch(65% 0.01 255); text-decoration: none; transition: color 0.15s; }
  .footer-link:hover { color: white; }
  .footer-muni-name { font-size: 0.875rem; color: white; margin-bottom: 4px; }
  .footer-muni-more { font-size: 0.8125rem; color: oklch(45% 0.008 255); font-style: italic; }
  .footer-source { margin-top: 16px; font-size: 0.75rem; color: oklch(40% 0.008 255); }
  .footer-source-link { text-decoration: underline; color: inherit; }
  .footer-bottom { padding-top: 20px; border-top: 1px solid oklch(28% 0.01 255); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; font-size: 0.75rem; color: oklch(45% 0.008 255); }

  @media (max-width: 768px) {
    .utility-bar { padding: 5px 16px; }
    .header-inner { padding: 14px 16px; }
    .main-nav { display: none; }
    .site-footer { padding: 40px 16px 24px; }
    .footer-grid { grid-template-columns: 1fr; gap: 28px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; gap: 4px; }
  }
</style>
