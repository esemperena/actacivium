---
interface Props {
  pleno: {
    id: string;
    numero_acta: number;
    fecha: string;
    tipo_sesion: string;
    resumen_ia: string | null;
    municipio: string;
    total_puntos: number;
    aprobados: number;
    rechazados: number;
    unanimes: number;
    n_asistentes?: number | null;
  };
  featured?: boolean;
}

const { pleno, featured = false } = Astro.props;

const fecha = new Date(pleno.fecha + "T12:00:00");
const fechaLarga = fecha.toLocaleDateString("es-ES", {
  day: "numeric", month: "long", year: "numeric",
});
const diaSemana = fecha.toLocaleDateString("es-ES", { weekday: "long" });
const esExtraordinaria = pleno.tipo_sesion === "extraordinaria";
---

<article style={`border-bottom: 1px solid var(--color-border); padding: ${featured ? "28px 0" : "20px 0"};`}>

  <!-- Etiquetas superiores -->
  <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-bottom: 8px;">
    <span style="font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-ink-subtle);">
      Pleno nº {pleno.numero_acta}
    </span>
    {esExtraordinaria && (
      <span class="badge" style="background: var(--color-amber-bg); color: var(--color-amber);">Extraordinaria</span>
    )}
  </div>

  <!-- Título / fecha -->
  <a href={`/acta/${pleno.id}`} style="display: block; text-decoration: none;">
    <time
      datetime={pleno.fecha}
      style={`
        font-family: var(--font-serif);
        font-weight: 700;
        font-size: ${featured ? "clamp(1.25rem, 2.5vw, 1.875rem)" : "clamp(1rem, 1.8vw, 1.35rem)"};
        line-height: 1.2;
        letter-spacing: -0.02em;
        text-transform: capitalize;
        color: var(--color-ink);
        display: block;
        margin-bottom: 6px;
        transition: color 0.15s;
      `}
      class="pleno-fecha-link"
    >
      {diaSemana}, {fechaLarga}
    </time>

    {pleno.resumen_ia && (
      <p style={`
        color: var(--color-ink-muted);
        line-height: 1.65;
        font-size: ${featured ? "0.9375rem" : "0.875rem"};
        margin-top: 4px;
      `}>
        {pleno.resumen_ia.length > 200
          ? pleno.resumen_ia.slice(0, 200) + "…"
          : pleno.resumen_ia}
      </p>
    )}
  </a>

  <!-- Stats -->
  <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 16px; margin-top: 10px; font-size: 0.8125rem; color: var(--color-ink-subtle);">
    <span style="font-weight: 600; color: var(--color-ink);">
      {pleno.total_puntos} {pleno.total_puntos === 1 ? "punto" : "puntos"}
    </span>
    {pleno.aprobados > 0 && (
      <span class="resultado-aprobado">{pleno.aprobados} aprobados</span>
    )}
    {pleno.rechazados > 0 && (
      <span class="resultado-rechazado">{pleno.rechazados} rechazados</span>
    )}
    {pleno.unanimes > 0 && (
      <span>{pleno.unanimes} por unanimidad</span>
    )}
    {pleno.n_asistentes && (
      <span>{pleno.n_asistentes} concejales</span>
    )}
    <a
      href={`/acta/${pleno.id}`}
      style="margin-left: auto; font-size: 0.8125rem; font-weight: 600; color: var(--color-accent); text-decoration: none;"
    >
      Ver acta →
    </a>
  </div>
</article>

<style>
  .pleno-fecha-link:hover {
    color: var(--color-accent) !important;
  }
  article:hover .pleno-fecha-link {
    color: var(--color-accent);
  }
</style>
