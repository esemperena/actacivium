---
interface Props {
  punto: {
    id: string;
    numero: number;
    titulo: string;
    categoria: string;
    tipo: string;
    resultado: string;
    unanimidad: boolean | null;
    resumen_ia: string | null;
    relevancia_social: number | null;
    es_urgencia: boolean;
  };
}

const { punto } = Astro.props;

const CATEGORIAS: Record<string, string> = {
  urbanismo: "Urbanismo", vivienda: "Vivienda", hacienda: "Hacienda",
  medio_ambiente: "Medio Ambiente", servicios_sociales: "Serv. Sociales",
  movilidad: "Movilidad", cultura: "Cultura", gobernanza: "Gobernanza",
  derechos: "Derechos", seguridad: "Seguridad", educacion: "Educación", otro: "Otro",
};

const TIPO_LABEL: Record<string, string> = {
  dar_cuenta: "Dar cuenta", aprobacion_definitiva: "Aprobación definitiva",
  aprobacion_inicial: "Aprobación inicial", declaracion_institucional: "Declaración institucional",
  mocion: "Moción", ruego: "Ruego", pregunta_oral: "Pregunta oral",
  interpelacion: "Interpelación", otro: "Trámite", proposicion_normativa: "Prop. normativa",
};

const RESULTADO_LABEL: Record<string, string> = {
  aprobado: "Aprobado", rechazado: "Rechazado",
  enterado: "Enterado", retirado: "Retirado", sin_votacion: "—",
};

const categoriaLabel = CATEGORIAS[punto.categoria] ?? punto.categoria;
const resultadoLabel  = RESULTADO_LABEL[punto.resultado] ?? punto.resultado;
const tipoLabel       = TIPO_LABEL[punto.tipo] ?? punto.tipo;
const esRelevante     = (punto.relevancia_social ?? 0) >= 4;

const borderStyle = esRelevante
  ? "3px solid var(--color-accent)"
  : punto.es_urgencia
  ? "3px solid var(--color-amber)"
  : "1px solid var(--color-border)";

const resultadoStyle = punto.resultado === "aprobado"
  ? "color: var(--color-green); font-weight: 600;"
  : punto.resultado === "rechazado"
  ? "color: var(--color-red); font-weight: 600;"
  : "color: var(--color-ink-subtle);";
---

<li style={`
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-left: ${borderStyle};
  border-radius: var(--radius);
  padding: 16px 18px;
  transition: box-shadow 0.15s;
  list-style: none;
`}
  class="punto-item"
>
  <div style="display: flex; gap: 12px; align-items: flex-start;">

    <!-- Número -->
    <span style="font-family: monospace; font-size: 0.75rem; font-weight: 600; color: var(--color-ink-subtle); min-width: 22px; padding-top: 1px;">
      {punto.numero}.
    </span>

    <!-- Contenido -->
    <div style="flex: 1; min-width: 0;">
      <p style="font-family: var(--font-serif); font-weight: 600; font-size: 0.9375rem; line-height: 1.4; margin-bottom: 8px;">
        {punto.titulo}
      </p>

      <div style="display: flex; flex-wrap: wrap; gap: 6px; align-items: center;">
        {punto.categoria && (
          <span class:list={["badge", `badge-${punto.categoria}`]}>
            {categoriaLabel}
          </span>
        )}
        <span style="font-size: 0.6875rem; color: var(--color-ink-subtle); border: 1px solid var(--color-border); border-radius: 3px; padding: 1px 6px; letter-spacing: 0.04em;">
          {tipoLabel}
        </span>
        {punto.es_urgencia && (
          <span class="badge" style="background: var(--color-amber-bg); color: var(--color-amber);">Urgencia</span>
        )}
        {esRelevante && (
          <span style="display: flex; align-items: center; gap: 3px;">
            {Array.from({ length: punto.relevancia_social ?? 0 }).map(() => (
              <span style="width: 5px; height: 5px; border-radius: 50%; background: var(--color-accent); display: inline-block;" />
            ))}
            <span style="font-size: 0.625rem; color: var(--color-accent); letter-spacing: 0.05em; text-transform: uppercase; font-weight: 600; margin-left: 2px;">
              Alta relevancia
            </span>
          </span>
        )}
      </div>

      {punto.resumen_ia && (
        <p style="font-size: 0.8125rem; color: var(--color-ink-muted); margin-top: 8px; line-height: 1.6;">
          {punto.resumen_ia}
        </p>
      )}
    </div>

    <!-- Resultado -->
    <span style={`font-size: 0.8125rem; white-space: nowrap; padding-top: 2px; ${resultadoStyle}`}>
      {resultadoLabel}
      {punto.unanimidad && punto.resultado === "aprobado" && (
        <span style="font-weight: 400; color: var(--color-ink-subtle); font-size: 0.75rem;"> · unanimidad</span>
      )}
    </span>
  </div>
</li>

<style>
  .punto-item:hover {
    box-shadow: var(--shadow-sm);
  }
</style>
