---
import ParlamentArc from './ParlamentArc';
import { CATEGORIAS } from '../lib/supabase';
import type { CityDashboardData, Municipio } from '../lib/supabase';

interface Props {
  municipio: Municipio;
  dashboard: CityDashboardData;
  introText?: string;
}

const { municipio, dashboard, introText } = Astro.props;

const totalConcejales =
  dashboard.composicion.reduce((sum, item) => sum + item.concejales, 0) ||
  municipio.n_representantes ||
  0;

const compactDate = (value: string) =>
  new Date(`${value}T12:00:00`).toLocaleDateString('es-ES', {
    month: 'short',
    year: 'numeric',
  });

const summaryCards = [
  {
    label: 'Plenos',
    value: dashboard.summary.totalPlenos,
    note:
      dashboard.summary.firstDate && dashboard.summary.lastDate
        ? `${compactDate(dashboard.summary.firstDate)} → ${compactDate(dashboard.summary.lastDate)}`
        : 'Sin cobertura todavia',
    tone: '',
  },
  {
    label: 'Puntos',
    value: dashboard.summary.totalPuntos,
    note: `${dashboard.summary.avgPuntos.toFixed(1)} por sesion`,
    tone: '',
  },
  {
    label: 'Aprobados',
    value: dashboard.summary.totalAprobados,
    note:
      dashboard.summary.totalPuntos > 0
        ? `${Math.round((dashboard.summary.totalAprobados / dashboard.summary.totalPuntos) * 100)}% del total`
        : 'Sin datos',
    tone: 'dashboard-stat--good',
  },
  {
    label: 'Unanimes',
    value: dashboard.summary.totalUnanimes,
    note:
      dashboard.summary.attendanceAvg !== null
        ? `${dashboard.summary.attendanceAvg.toFixed(1)} concejales de media`
        : 'Asistencia no disponible',
    tone: 'dashboard-stat--soft',
  },
];

const pairKey = (partyA: string, partyB: string) => `${partyA}__${partyB}`;

const pairColumns = dashboard.alignments
  .slice(0, 6)
  .map((item) => ({
    key: pairKey(item.partyA, item.partyB),
    label: `${item.partyA} / ${item.partyB}`,
    shortLabel: `${item.partyA}·${item.partyB}`,
  }));

const alignmentRows = dashboard.alignmentByCategory
  .filter((row) => row.categoria !== 'otro')
  .slice(0, 5)
  .map((row) => {
    const lookup = new Map(row.pairs.map((pair) => [pairKey(pair.partyA, pair.partyB), pair]));
    return {
      ...row,
      cells: pairColumns.map((column) => lookup.get(column.key) ?? null),
    };
  });

const conflictRows = dashboard.lowConsensusCategories
  .filter((row) => row.categoria !== 'otro')
  .slice(0, 5);

const proposalCards = [
  {
    key: 'gobierno',
    label: 'Propuestas del gobierno',
    data: dashboard.proposalSummary.gobierno,
    tone: 'proposal-card--government',
  },
  {
    key: 'oposicion',
    label: 'Propuestas de la oposicion',
    data: dashboard.proposalSummary.oposicion,
    tone: 'proposal-card--opposition',
  },
];

const featuredPoints = dashboard.featuredPoints.slice(0, 4);

const blockLabel = (value: 'gobierno' | 'oposicion' | 'sin_clasificar') => {
  if (value === 'gobierno') return 'Gobierno';
  if (value === 'oposicion') return 'Oposicion';
  return 'Sin clasificar';
};

const heatBackground = (share: number) => {
  if (share >= 0.75) return 'oklch(92% 0.04 155)';
  if (share >= 0.6) return 'oklch(94.5% 0.03 155)';
  if (share >= 0.4) return 'oklch(96.5% 0.01 240)';
  if (share >= 0.25) return 'oklch(95% 0.025 22)';
  return 'oklch(92.5% 0.04 22)';
};

const heatColor = (share: number) => {
  if (share >= 0.6) return 'var(--color-green)';
  if (share >= 0.4) return 'var(--color-ink-muted)';
  return 'var(--color-red)';
};
---

<section class="dashboard-shell">
  <div class="dashboard-hero">
    <div class="dashboard-hero-copy">
      <p class="dashboard-kicker">Radar municipal</p>
      <h2 class="dashboard-title">Actividad del pleno de {municipio.nombre_alt ?? municipio.nombre} · Sesiones y votaciones</h2>
      <p class="dashboard-subtitle">
        {introText ?? "Lectura rapida de actividad, temas dominantes, grado de consenso y bloques de voto."}
      </p>
    </div>

    <div class="dashboard-stat-grid">
      {summaryCards.map((card) => (
        <article class:list={['dashboard-stat', card.tone]}>
          <p class="dashboard-stat-label">{card.label}</p>
          <p class="dashboard-stat-value">{card.value}</p>
          <p class="dashboard-stat-note">{card.note}</p>
        </article>
      ))}
    </div>
  </div>

  <div class="dashboard-overview-grid">
    <section class="dashboard-panel dashboard-panel--compact dashboard-panel--equal">
      <div class="dashboard-panel-head dashboard-panel-head--tight">
        <p class="dashboard-panel-kicker">Composicion</p>
        <h3 class="dashboard-panel-title dashboard-panel-title--sm">Composición del Ayuntamiento de {municipio.nombre}</h3>
      </div>

      {dashboard.composicion.length > 0 ? (
        <div class="dashboard-composition">
          <div class="dashboard-arc-wrap">
            <ParlamentArc composicion={dashboard.composicion} total={totalConcejales} client:load />
          </div>
          <div class="dashboard-facts">
            {municipio.partido_gobierno && (
              <div class="dashboard-fact">
                <span class="dashboard-fact-label">Gobierno</span>
                <span class="dashboard-fact-value">{municipio.partido_gobierno}</span>
              </div>
            )}
            {municipio.alcalde && (
              <div class="dashboard-fact">
                <span class="dashboard-fact-label">Alcaldia</span>
                <span class="dashboard-fact-value">{municipio.alcalde}</span>
              </div>
            )}
            {municipio.poblacion && (
              <div class="dashboard-fact">
                <span class="dashboard-fact-label">Poblacion</span>
                <span class="dashboard-fact-value">{municipio.poblacion.toLocaleString('es-ES')} hab.</span>
              </div>
            )}
          </div>
        </div>
      ) : (
        <p class="dashboard-empty">La composicion del pleno todavia no esta disponible.</p>
      )}
    </section>

    <section class="dashboard-panel dashboard-panel--compact dashboard-panel--equal">
      <div class="dashboard-panel-head dashboard-panel-head--tight">
        <p class="dashboard-panel-kicker">Agenda</p>
        <h3 class="dashboard-panel-title dashboard-panel-title--sm">Temas más debatidos en el pleno</h3>
      </div>

      <div class="dashboard-bars dashboard-bars--compact">
        {dashboard.categoryStats.slice(0, 6).map((item) => (
          <div class="dashboard-bar-row">
            <div class="dashboard-bar-meta">
              <span class:list={['badge', `badge-${item.categoria}`]}>{item.label}</span>
              <span class="dashboard-bar-count">{item.total}</span>
            </div>
            <div class="dashboard-bar-track">
              <div class="dashboard-bar-fill" style={`width:${Math.max(item.share * 100, 8)}%`} />
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <section class="dashboard-panel dashboard-panel--full">
      <div class="dashboard-panel-head">
        <p class="dashboard-panel-kicker">Coincidencia por tema</p>
        <h3 class="dashboard-panel-title">Alianzas de voto por tema</h3>
      </div>

      {alignmentRows.length > 0 && pairColumns.length > 0 ? (
        <div class="alignment-matrix">
          <div class="alignment-matrix-header">
            <div class="alignment-corner">Tema</div>
            {pairColumns.map((column) => (
              <div class="alignment-col-label" title={column.label}>{column.shortLabel}</div>
            ))}
          </div>

          {alignmentRows.map((row) => (
            <div class="alignment-row">
              <div class="alignment-row-label">
                <span class:list={['badge', `badge-${row.categoria}`]}>{row.label}</span>
              </div>
              {row.cells.map((cell) => (
                cell ? (
                  <div
                    class="alignment-cell"
                    style={`background:${heatBackground(cell.sameVoteShare)}; color:${heatColor(cell.sameVoteShare)}`}
                    title={`${cell.partyA} y ${cell.partyB}: ${Math.round(cell.sameVoteShare * 100)}% (${cell.sameVotes}/${cell.comparedPoints})`}
                  >
                    <span class="alignment-cell-value">{Math.round(cell.sameVoteShare * 100)}%</span>
                    <span class="alignment-cell-note">{cell.comparedPoints} vot.</span>
                  </div>
                ) : (
                  <div class="alignment-cell alignment-cell--empty">—</div>
                )
              ))}
            </div>
          ))}
        </div>
      ) : (
        <p class="dashboard-empty">Todavia no hay suficientes votaciones comparables por tema.</p>
      )}
  </section>

</section>

<style>
  .dashboard-shell {
    margin-bottom: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .dashboard-hero {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    align-items: stretch;
  }
  .dashboard-hero-copy,
  .dashboard-stat-grid,
  .dashboard-panel {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }
  .dashboard-hero-copy {
    padding: 16px 20px;
    background:
      linear-gradient(135deg, oklch(99% 0.012 160) 0%, oklch(100% 0 0) 65%),
      var(--color-bg-card);
  }
  .dashboard-kicker,
  .dashboard-panel-kicker {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .dashboard-title {
    margin-top: 6px;
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 2.3vw, 1.65rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    max-width: 14ch;
  }
  .dashboard-subtitle {
    margin-top: 8px;
    max-width: 58ch;
    font-size: 0.825rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
  }

  .dashboard-stat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    overflow: hidden;
  }
  .dashboard-stat {
    padding: 12px 14px 10px;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .dashboard-stat:nth-child(2n) { border-right: none; }
  .dashboard-stat:nth-last-child(-n+2) { border-bottom: none; }
  .dashboard-stat-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
  }
  .dashboard-stat-value {
    margin-top: 6px;
    font-family: var(--font-serif);
    font-size: 1.45rem;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-ink);
  }
  .dashboard-stat-note {
    margin-top: 5px;
    font-size: 0.69rem;
    line-height: 1.4;
    color: var(--color-ink-muted);
  }
  .dashboard-stat--good .dashboard-stat-value { color: var(--color-green); }
  .dashboard-stat--soft .dashboard-stat-value { color: var(--color-accent); }

  .dashboard-overview-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    align-items: stretch;
  }
  .dashboard-insight-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
    gap: 14px;
    align-items: start;
  }
  .dashboard-insight-grid > .dashboard-panel:last-child {
    grid-column: 1 / -1;
  }
  .dashboard-panel {
    padding: 14px;
  }
  .dashboard-panel--compact {
    padding: 12px;
  }
  .dashboard-panel--equal {
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .dashboard-panel--full {
    width: 100%;
  }
  .dashboard-panel-head {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 10px;
  }
  .dashboard-panel-head--tight {
    margin-bottom: 8px;
  }
  .dashboard-panel-title {
    font-family: var(--font-serif);
    font-size: 0.975rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  .dashboard-panel-title--sm {
    font-size: 0.9rem;
  }

  .dashboard-composition {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
    justify-content: space-between;
  }
  .dashboard-arc-wrap {
    max-width: 260px;
    margin: 0 auto;
    width: 100%;
  }
  .dashboard-arc-wrap :global(svg) {
    margin-bottom: 8px !important;
  }
  .dashboard-facts {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .dashboard-fact {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: baseline;
  }
  .dashboard-fact-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
  }
  .dashboard-fact-value {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-ink);
    text-align: right;
  }

  .dashboard-bars {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
    justify-content: space-between;
  }
  .dashboard-bars--compact {
    gap: 8px;
  }
  .dashboard-bar-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 6px;
  }
  .dashboard-bar-meta {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    align-items: center;
  }
  .dashboard-bar-count {
    font-size: 0.75rem;
    color: var(--color-ink-subtle);
  }
  .dashboard-bar-track {
    height: 8px;
    border-radius: 999px;
    background: var(--color-accent-xlight);
    overflow: hidden;
  }
  .dashboard-bar-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-accent-mid) 100%);
  }

  .alignment-matrix {
    display: grid;
    gap: 8px;
  }
  .alignment-matrix-header,
  .alignment-row {
    display: grid;
    grid-template-columns: 132px repeat(6, minmax(0, 1fr));
    gap: 8px;
    align-items: stretch;
  }
  .alignment-corner,
  .alignment-col-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
  }
  .alignment-col-label {
    text-align: center;
    padding-bottom: 2px;
  }
  .alignment-row-label {
    display: flex;
    align-items: center;
  }
  .alignment-cell {
    min-height: 56px;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    text-align: center;
    padding: 8px 6px;
  }
  .alignment-cell--empty {
    background: oklch(99.4% 0.003 240);
    color: var(--color-ink-subtle);
  }
  .alignment-cell-value {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1;
  }
  .alignment-cell-note {
    font-size: 0.62rem;
    color: inherit;
    opacity: 0.85;
  }

  .conflict-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .featured-points-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }
  .featured-point-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 14px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: linear-gradient(180deg, oklch(99.2% 0.007 160) 0%, var(--color-bg-card) 100%);
    color: inherit;
    min-height: 170px;
  }
  .featured-point-card:hover {
    box-shadow: var(--shadow-sm);
  }
  .featured-point-top,
  .featured-point-footer {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .featured-point-acta,
  .featured-point-date,
  .featured-point-relevance {
    font-size: 0.68rem;
    color: var(--color-ink-subtle);
  }
  .featured-point-acta {
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .featured-point-title {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-ink);
    font-weight: 600;
  }
  .featured-point-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }
  .featured-point-block {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    border-radius: 999px;
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    background: oklch(96.5% 0.01 240);
    color: var(--color-ink-muted);
  }
  .featured-point-block--gobierno {
    background: var(--color-accent-xlight);
    color: var(--color-accent);
  }
  .featured-point-block--oposicion {
    background: var(--color-red-bg);
    color: var(--color-red);
  }

  .proposal-grid {
    display: grid;
    gap: 10px;
  }
  .proposal-card {
    padding: 14px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-card);
  }
  .proposal-card--government {
    background: linear-gradient(180deg, var(--color-accent-xlight) 0%, var(--color-bg-card) 100%);
  }
  .proposal-card--opposition {
    background: linear-gradient(180deg, var(--color-red-bg) 0%, var(--color-bg-card) 100%);
  }
  .proposal-card-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
  }
  .proposal-card-top {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-top: 8px;
  }
  .proposal-card-value {
    font-family: var(--font-serif);
    font-size: 1.7rem;
    line-height: 1;
    color: var(--color-ink);
  }
  .proposal-card-note,
  .proposal-card-foot {
    font-size: 0.74rem;
    color: var(--color-ink-muted);
  }
  .proposal-track {
    height: 8px;
    border-radius: 999px;
    overflow: hidden;
    margin-top: 10px;
    background: oklch(95% 0.008 240);
  }
  .proposal-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-green) 100%);
  }
  .proposal-card-foot {
    margin-top: 7px;
    line-height: 1.45;
  }
  .conflict-card {
    padding: 12px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-card);
  }
  .conflict-top {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: center;
  }
  .conflict-value {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1;
    color: var(--color-red);
  }
  .conflict-track {
    height: 8px;
    border-radius: 999px;
    overflow: hidden;
    margin-top: 10px;
    background: var(--color-red-bg);
  }
  .conflict-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--color-red-mid) 0%, var(--color-red) 100%);
  }
  .conflict-note {
    margin-top: 7px;
    font-size: 0.72rem;
    color: var(--color-ink-subtle);
    line-height: 1.45;
  }

  .dashboard-empty {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    line-height: 1.6;
  }

  @media (max-width: 1100px) {
    .dashboard-overview-grid,
    .dashboard-hero,
    .dashboard-insight-grid {
      grid-template-columns: 1fr;
    }
    .dashboard-insight-grid > .dashboard-panel:last-child {
      grid-column: auto;
    }
  }

  @media (max-width: 768px) {
    .dashboard-shell {
      gap: 12px;
      margin-bottom: 24px;
    }
    .dashboard-hero-copy,
    .dashboard-panel,
    .dashboard-panel--compact {
      padding: 16px;
    }
    .dashboard-stat-grid {
      grid-template-columns: 1fr 1fr;
    }
    .featured-points-grid {
      grid-template-columns: 1fr;
    }
    .alignment-matrix-header,
    .alignment-row {
      grid-template-columns: 110px repeat(3, minmax(0, 1fr));
    }
    .alignment-matrix-header .alignment-col-label:nth-child(n + 5),
    .alignment-row .alignment-cell:nth-child(n + 5) {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .dashboard-stat-grid {
      grid-template-columns: 1fr;
    }
    .dashboard-stat {
      border-right: none;
    }
    .dashboard-stat:not(:last-child) {
      border-bottom: 1px solid var(--color-border);
    }
    .dashboard-stat:nth-last-child(-n+2) {
      border-bottom: 1px solid var(--color-border);
    }
    .dashboard-stat:last-child {
      border-bottom: none;
    }
    .alignment-matrix-header,
    .alignment-row {
      grid-template-columns: 96px repeat(2, minmax(0, 1fr));
    }
    .alignment-matrix-header .alignment-col-label:nth-child(n + 4),
    .alignment-row .alignment-cell:nth-child(n + 4) {
      display: none;
    }
  }
</style>
