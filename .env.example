# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-service-role-key

# ── Web (variables públicas para Astro) ───────────────────────
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Brevo (newsletter) ────────────────────────────────────────
BREVO_API_KEY=your-brevo-api-key
BREVO_LIST_ID=3          # ID de la lista en Brevo
PUBLIC_BREVO_API_URL=/api/subscribe

# ── Scraper ───────────────────────────────────────────────────
PDF_TEMP_DIR=C:\Users\TuUsuario\AppData\Local\Temp\actacivium
PDF_MAX_PAGES_FOR_SUMMARY=60
CLAUDE_CMD=claude         # comando claude Code CLI en tu PATH
NEWSLETTER_MIN_RELEVANCIA=3
